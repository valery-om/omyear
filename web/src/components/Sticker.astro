---
/**
 * Little hand-drawn sticker accents (scrapbook style).
 * Inline SVG, palette only (terracotta / gold / sea-glass), no external assets.
 */
interface Props {
  name: "sun" | "spark" | "wave" | "shell" | "heart" | "palm";
  class?: string;
  size?: number;
}
const { name, class: cls, size = 30 } = Astro.props;
const terracotta = "var(--terracotta, #C26B43)";
const gold = "var(--gold, #E3AE49)";
const sea = "var(--sea-deep, #5FA8A0)";
---
<span class:list={["sticker", `sticker--${name}`, cls]} aria-hidden="true">
  {name === "sun" && (
    <svg width={size} height={size} viewBox="0 0 30 30" fill="none">
      <circle cx="15" cy="15.4" r="5.2" fill={gold} opacity="0.9" />
      <path d="M15 6.2 L14.8 3.4 M21.3 9 L23.2 7 M23.8 15.2 L26.6 15.5 M21.2 21.6 L23 23.6 M15.2 24.4 L15 27 M8.9 21.4 L6.8 23.2 M6.2 15 L3.4 14.8 M9 8.8 L7.2 6.9"
        stroke={terracotta} stroke-width="1.5" stroke-linecap="round" />
    </svg>
  )}
  {name === "spark" && (
    <svg width={size} height={size} viewBox="0 0 24 24" fill="none">
      <path d="M12 2.2 C12.7 8 13.9 9.5 21.6 11.8 C14 13.4 13 14.8 12.2 21.8 C11.2 14.9 10 13.3 2.6 11.6 C10.1 9.6 11.3 8.3 12 2.2 Z"
        fill={gold} opacity="0.92" />
      <circle cx="19.6" cy="4.6" r="1.3" fill={terracotta} opacity="0.8" />
    </svg>
  )}
  {name === "wave" && (
    <svg width={size * 1.4} height={size * 0.62} viewBox="0 0 42 18" fill="none">
      <path d="M2 7.2 Q6.5 2.4 11.2 6.8 T20.6 6.9 T30 6.6 T39.6 6.9"
        stroke={sea} stroke-width="1.7" stroke-linecap="round" />
      <path d="M6.5 13.6 Q10.6 9.6 15 13.2 T24 13.4 T33.2 13"
        stroke={sea} stroke-width="1.5" stroke-linecap="round" opacity="0.62" />
    </svg>
  )}
  {name === "shell" && (
    <svg width={size} height={size * 0.9} viewBox="0 0 28 25" fill="none">
      <path d="M14 22.6 C8.4 20.8 4.6 16 4.3 10.2 C4.2 7.6 5.4 5.2 7.4 4 C9.2 6.4 11 6.6 14 6.5 C17 6.6 18.9 6.3 20.7 4.1 C22.6 5.3 23.8 7.7 23.7 10.3 C23.4 16 19.6 20.9 14 22.6 Z"
        stroke={terracotta} stroke-width="1.5" stroke-linejoin="round" fill="rgba(241,188,106,0.22)" />
      <path d="M14 22.2 L14 6.6 M9.2 20 C8 15.8 7.9 11.4 8.8 5.6 M18.9 19.9 C20 15.7 20.1 11.3 19.3 5.7"
        stroke={terracotta} stroke-width="1.2" stroke-linecap="round" opacity="0.75" />
    </svg>
  )}
  {name === "heart" && (
    <svg width={size} height={size * 0.92} viewBox="0 0 26 24" fill="none">
      <path d="M13 21.2 C6 16.4 2.6 11.6 4.2 7.2 C5.4 4 9.4 3.4 12.9 7.4 C15.2 3.6 19.9 3.3 21.6 6.6 C23.7 10.8 20.2 16.2 13 21.2 Z"
        stroke={terracotta} stroke-width="1.6" stroke-linejoin="round" fill="rgba(194,107,67,0.14)" />
      <path d="M22.4 2.4 L23.2 4.5 M25 5.4 L23.1 6.1" stroke={gold} stroke-width="1.4" stroke-linecap="round" />
    </svg>
  )}
  {name === "palm" && (
    <svg width={size} height={size} viewBox="0 0 30 30" fill="none">
      <path d="M5.2 26.4 C10 20.4 16.4 13.6 26 6.4" stroke={sea} stroke-width="1.6" stroke-linecap="round" />
      <path d="M9.6 21 C7.8 18.6 7.4 15.8 8.2 12.8 M13.4 16.8 C11.8 14 11.7 11 12.7 8 M17.6 12.6 C16.6 9.8 16.8 7.2 18 4.4"
        stroke={sea} stroke-width="1.4" stroke-linecap="round" opacity="0.85" />
      <path d="M10.4 20.2 C13.4 20.4 15.9 21.4 17.8 23.4 M14.4 15.9 C17.4 15.7 20 16.4 22.2 18.2 M18.6 11.6 C21.3 11 23.8 11.3 26.2 12.6"
        stroke={sea} stroke-width="1.4" stroke-linecap="round" opacity="0.68" />
    </svg>
  )}
</span>
