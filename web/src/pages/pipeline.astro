---
import Layout from "../layouts/Layout.astro";
import Sun from "../components/Sun.astro";
import demo from "../data/people/maya-demo.json";

const provenance = demo.provenance;
const verification = provenance.verification;
const liveModel = provenance.generationModel !== "fixture";
const stages = [
  { n: "01", label: "INTAKE", title: "A person, not a prompt", text: "The questionnaire records confirmed facts, goals, birth data, return location and a gift message in a strict input schema.", artifact: "input.json" },
  { n: "02", label: "CALCULATE", title: "Numbers before prose", text: "Python computes numerology, the 22-arcana matrix, natal and solar-return charts, Human Design activations and nearest astrocartography lines.", artifact: "calc.json" },
  { n: "03", label: "REGISTER", title: "Every fact gets an address", text: "Inputs and calculations become immutable source records such as calc.period.4 or input.goal.rest. The model can cite only these IDs.", artifact: `${provenance.sourceCount} source records` },
  { n: "04", label: "WRITE · GPT-5.6", title: "Creativity inside a boundary", text: "GPT-5.6 receives the source registry, editorial constraints and a JSON Schema. Every interpretive object must return its exact sourceIds.", artifact: "draft.json" },
  { n: "05", label: "VERIFY", title: "Trust, then check", text: "A deterministic verifier rejects unknown citations and missing sections, checks all 12 periods and practices, and flags certainty or sensitive language.", artifact: "verification.json" },
  { n: "06", label: "REVIEW", title: "A human keeps the last word", text: "Cross-framework synthesis and low-confidence passages stay visible. The pipeline cannot label a draft ready for delivery without editorial approval.", artifact: `${verification.humanReview.flaggedPaths.length} review ${verification.humanReview.flaggedPaths.length === 1 ? "flag" : "flags"}` },
  { n: "07", label: "PUBLISH", title: "One dataset, one living book", text: "The approved draft compiles into the existing Omyear book format and Astro builds the private, responsive reading experience.", artifact: "/0811" },
];
---

<Layout
  title="Omyear pipeline — from questionnaire to a source-linked personal year book"
  description="A sequential GPT-5.6 pipeline that calculates, writes, verifies and compiles a personalized year book."
  music={false}
  language="en"
>
  <main class="pipe">
    <header class="pipe-hero">
      <nav class="pipe-nav" aria-label="Page navigation">
        <a href="/">omyear</a>
        <span>Build Week · 2026</span>
      </nav>
      <div class="pipe-hero__orbit" aria-hidden="true">
        <span class="pipe-hero__sun"></span><span class="pipe-hero__path pipe-hero__path--a"></span><span class="pipe-hero__path pipe-hero__path--b"></span>
      </div>
      <div class="pipe-hero__copy">
        <p class="pipe-kicker">apps for your life · sequential AI pipeline</p>
        <h1>A year book that can<br /><em>show its work.</em></h1>
        <p class="pipe-lede">Omyear turns confirmed life context and deterministic symbolic calculations into a warm personal book—without letting generated prose outrun its sources.</p>
        <div class="pipe-actions">
          <a class="pipe-button pipe-button--solid" href="/0811">Open Maya’s demo <span>↗</span></a>
          <a class="pipe-button" href="#sequence">Trace the sequence <span>↓</span></a>
        </div>
        <p class="pipe-build-state" data-state={liveModel ? "live" : "rehearsal"}>
          <span></span>{liveModel ? `Demo generated with ${provenance.generationModel}` : "Validated rehearsal artifact · GPT-5.6 API run pending"}
        </p>
      </div>
    </header>

    <section class="pipe-snapshot" aria-label="Current demo verification snapshot">
      <div><small>source records</small><strong>{provenance.sourceCount}</strong></div>
      <div><small>sources cited</small><strong>{verification.referencedClaimCount}</strong></div>
      <div><small>source-link errors</small><strong>{verification.invalidSourceIds.length + verification.missingSourcePaths.length}</strong></div>
      <div><small>year chapters</small><strong>12</strong></div>
    </section>

    <section class="pipe-sequence" id="sequence">
      <div class="pipe-section-head">
        <Sun size={30} />
        <p>one run · seven proofs</p>
        <h2>From a birthday to a book,<br />in an inspectable line.</h2>
      </div>
      <ol class="pipe-stages">
        {stages.map((stage, index) => (
          <li class="pipe-stage" style={`--delay:${index * 70}ms`} data-reveal>
            <div class="pipe-stage__rail"><span>{stage.n}</span><i></i></div>
            <div class="pipe-stage__body">
              <p class="pipe-stage__label">{stage.label}</p>
              <h3>{stage.title}</h3>
              <p>{stage.text}</p>
            </div>
            <code>{stage.artifact}</code>
          </li>
        ))}
      </ol>
    </section>

    <section class="pipe-boundary">
      <div class="pipe-boundary__copy">
        <p class="pipe-kicker">the editorial boundary</p>
        <h2>Four kinds of truth.<br />Never blurred together.</h2>
        <p>The interface labels what came from the person, what code calculated, what GPT‑5.6 interpreted, and what still needs a human decision.</p>
      </div>
      <div class="pipe-layers" aria-label="Information layers">
        <article><span>01</span><b>CONFIRMED</b><p>questionnaire facts and goals</p></article>
        <article><span>02</span><b>CALCULATED</b><p>repeatable numeric outputs</p></article>
        <article><span>03</span><b>INTERPRETED</b><p>source-linked model prose</p></article>
        <article><span>04</span><b>APPROVED</b><p>human editorial judgment</p></article>
      </div>
    </section>

    <section class="pipe-try">
      <p class="pipe-kicker">run the same path</p>
      <h2>One command. Every artifact kept.</h2>
      <pre><code><span>OPENAI_API_KEY</span>=… node pipeline/run.mjs \
  --input pipeline/examples/maya.json \
  --provider openai --model gpt-5.6-sol</code></pre>
      <p>The run directory preserves the input, calculations, exact prompt, structured draft, verification report, model metadata and compiled book.</p>
      <a class="pipe-button pipe-button--solid" href="/0811#provenance">Inspect the live source ledger <span>↗</span></a>
    </section>

    <footer class="pipe-footer"><span>OMYEAR / SOURCE-LINKED PERSONAL STORIES</span><a href="/">Back to the product</a></footer>
  </main>

  <style>
    .pipe { --pipe-max: 72rem; overflow: hidden; }
    .pipe-hero { position: relative; min-height: 92svh; padding: 1.2rem clamp(1.2rem, 5vw, 4rem) 5rem; display: grid; align-items: center; isolation: isolate; }
    .pipe-nav { position: absolute; inset: 1.2rem clamp(1.2rem, 5vw, 4rem) auto; z-index: 3; display: flex; justify-content: space-between; align-items: center; padding-bottom: .8rem; border-bottom: 1px solid var(--line); font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; }
    .pipe-nav a { color: var(--ink); font: 600 1.05rem/1 var(--font-display); letter-spacing: 0; text-transform: lowercase; text-decoration: none; }
    .pipe-nav span { color: var(--sienna); }
    .pipe-hero__copy { position: relative; z-index: 2; width: min(47rem, 92vw); margin: 6rem auto 0; }
    .pipe-kicker { margin: 0 0 1rem; color: var(--terracotta-deep); font-size: .66rem; letter-spacing: .26em; text-transform: uppercase; }
    .pipe-hero h1 { margin: 0; font: 500 clamp(3rem, 8vw, 6.7rem)/.93 var(--font-display); letter-spacing: -.035em; }
    .pipe-hero h1 em { color: var(--terracotta); font-weight: 400; }
    .pipe-lede { max-width: 35rem; margin: 1.8rem 0 0 auto; color: var(--ink-soft); font-size: clamp(1rem, 2vw, 1.25rem); line-height: 1.65; }
    .pipe-actions { display: flex; justify-content: flex-end; flex-wrap: wrap; gap: .7rem; margin-top: 1.8rem; }
    .pipe-button { display: inline-flex; align-items: center; gap: .75rem; padding: .78rem 1.15rem; border: 1px solid var(--line-strong); border-radius: 999px; color: var(--ink); font: 500 .85rem/1 var(--font-body); text-decoration: none; transition: transform .2s ease, background .2s ease; }
    .pipe-button:hover { transform: translateY(-2px); background: rgba(251,244,230,.7); }
    .pipe-button--solid { border-color: var(--terracotta); background: var(--terracotta); color: var(--paper); }
    .pipe-button--solid:hover { background: var(--terracotta-deep); }
    .pipe-build-state { display: flex; justify-content: flex-end; align-items: center; gap: .5rem; margin: 1rem 0 0; color: var(--sienna); font-size: .7rem; }
    .pipe-build-state span { width: .48rem; height: .48rem; border-radius: 50%; background: var(--gold); box-shadow: 0 0 0 5px rgba(227,174,73,.13); }
    .pipe-build-state[data-state="live"] span { background: #47715f; box-shadow: 0 0 0 5px rgba(71,113,95,.13); }
    .pipe-hero__orbit { position: absolute; z-index: -1; width: min(84vw, 54rem); aspect-ratio: 1; left: 48%; top: 49%; transform: translate(-50%,-50%); }
    .pipe-hero__sun { position: absolute; inset: 35%; border-radius: 50%; background: radial-gradient(circle at 40% 35%, var(--sun-glow), var(--sun) 62%, var(--terracotta)); box-shadow: 0 0 10rem 4rem rgba(241,188,106,.28); }
    .pipe-hero__path { position: absolute; inset: 10%; border: 1px solid rgba(154,106,69,.2); border-radius: 50%; animation: pipe-spin 80s linear infinite; }
    .pipe-hero__path::after { content: ""; position: absolute; top: 23%; right: 4%; width: .65rem; height: .65rem; border-radius: 50%; background: var(--terracotta); box-shadow: 0 0 0 7px rgba(194,107,67,.12); }
    .pipe-hero__path--b { inset: 2% 22%; transform: rotate(68deg); animation-direction: reverse; animation-duration: 66s; }
    @keyframes pipe-spin { to { transform: rotate(360deg); } }
    .pipe-snapshot { display: grid; grid-template-columns: repeat(4,1fr); max-width: var(--pipe-max); margin: 0 auto; padding: 0 1.3rem 5rem; }
    .pipe-snapshot div { min-height: 8rem; padding: 1.2rem; border: 1px solid var(--line); border-right: 0; background: rgba(251,244,230,.58); }
    .pipe-snapshot div:first-child { border-radius: 18px 0 0 18px; }
    .pipe-snapshot div:last-child { border-right: 1px solid var(--line); border-radius: 0 18px 18px 0; }
    .pipe-snapshot small { display: block; color: var(--sienna); font-size: .6rem; letter-spacing: .14em; text-transform: uppercase; }
    .pipe-snapshot strong { display: block; margin-top: 1rem; color: var(--terracotta-deep); font: 500 2.6rem/1 var(--font-display); }
    .pipe-sequence { max-width: var(--pipe-max); margin: 0 auto; padding: 5rem 1.3rem; border-top: 1px solid var(--line); }
    .pipe-section-head > p { margin: .7rem 0 .4rem; color: var(--terracotta-deep); font-size: .67rem; letter-spacing: .22em; text-transform: uppercase; }
    .pipe-section-head h2, .pipe-boundary h2, .pipe-try h2 { margin: 0; font: 500 clamp(2rem, 5vw, 3.5rem)/1.06 var(--font-display); }
    .pipe-stages { margin: 3rem 0 0; padding: 0; list-style: none; }
    .pipe-stage { display: grid; grid-template-columns: 4rem minmax(0,1fr) 11rem; gap: 1.2rem; min-height: 10.5rem; animation-delay: var(--delay); }
    .pipe-stage__rail { position: relative; display: grid; justify-items: center; }
    .pipe-stage__rail span { z-index: 1; display: grid; place-items: center; width: 2.7rem; height: 2.7rem; border: 1px solid var(--line-strong); border-radius: 50%; background: var(--cream); color: var(--terracotta-deep); font: 600 .75rem/1 var(--font-display); }
    .pipe-stage__rail i { position: absolute; top: 2.7rem; bottom: 0; width: 1px; background: linear-gradient(var(--line-strong), var(--line)); }
    .pipe-stage:last-child .pipe-stage__rail i { display: none; }
    .pipe-stage__body { padding: .1rem 0 2.2rem; }
    .pipe-stage__label { margin: 0; color: var(--terracotta-deep); font-size: .59rem; letter-spacing: .22em; }
    .pipe-stage h3 { margin: .35rem 0 .5rem; font: 600 1.45rem/1.2 var(--font-display); }
    .pipe-stage__body > p:last-child { max-width: 38rem; margin: 0; color: var(--ink-soft); font-size: .92rem; line-height: 1.55; }
    .pipe-stage > code { align-self: start; margin-top: .2rem; padding: .45rem .6rem; border: 1px solid var(--line); border-radius: 6px; color: var(--sienna); background: rgba(251,244,230,.55); font-size: .62rem; overflow-wrap: anywhere; }
    .pipe-boundary { display: grid; grid-template-columns: .8fr 1.2fr; gap: clamp(2rem,7vw,6rem); max-width: var(--pipe-max); margin: 0 auto; padding: 6rem 1.3rem; border-top: 1px solid var(--line); }
    .pipe-boundary__copy > p:last-child { max-width: 32rem; margin-top: 1.3rem; color: var(--ink-soft); font-size: .95rem; line-height: 1.6; }
    .pipe-layers { display: grid; transform: rotate(-1.5deg); }
    .pipe-layers article { display: grid; grid-template-columns: 3rem 8rem 1fr; gap: .8rem; align-items: baseline; padding: 1.2rem; border: 1px solid var(--line); border-bottom: 0; background: var(--paper); box-shadow: 0 18px 35px -30px rgba(70,48,28,.65); }
    .pipe-layers article:first-child { border-radius: 16px 16px 0 0; }
    .pipe-layers article:last-child { border-bottom: 1px solid var(--line); border-radius: 0 0 16px 16px; }
    .pipe-layers span { color: var(--gold); font: 600 .76rem/1 var(--font-display); }
    .pipe-layers b { color: var(--terracotta-deep); font-size: .64rem; letter-spacing: .13em; }
    .pipe-layers p { margin: 0; color: var(--ink-soft); font-size: .78rem; line-height: 1.35; }
    .pipe-try { max-width: calc(var(--pipe-max) - 2.6rem); margin: 2rem auto 6rem; padding: clamp(2rem,5vw,4rem); border: 1px solid var(--line); border-radius: 24px; background: var(--paper); }
    .pipe-try pre { margin: 2rem 0 1.2rem; padding: 1.3rem; overflow-x: auto; border-radius: 12px; background: var(--ink); color: var(--cream); font: .74rem/1.7 ui-monospace, SFMono-Regular, Menlo, monospace; }
    .pipe-try pre span { color: var(--sun-glow); }
    .pipe-try > p:not(.pipe-kicker) { max-width: 43rem; color: var(--ink-soft); font-size: .88rem; line-height: 1.6; }
    .pipe-try .pipe-button { margin-top: .8rem; }
    .pipe-footer { display: flex; justify-content: space-between; gap: 1rem; padding: 1.6rem clamp(1.2rem,5vw,4rem); border-top: 1px solid var(--line); color: var(--sienna); font-size: .6rem; letter-spacing: .13em; }
    .pipe-footer a { color: var(--terracotta-deep); }
    @media (max-width: 760px) {
      .pipe-hero { min-height: 84svh; padding-bottom: 3rem; }
      .pipe-hero__copy { margin-top: 5rem; }
      .pipe-hero h1 br { display: none; }
      .pipe-lede { margin-left: 0; }
      .pipe-actions, .pipe-build-state { justify-content: flex-start; }
      .pipe-snapshot { grid-template-columns: repeat(2,1fr); }
      .pipe-snapshot div, .pipe-snapshot div:first-child, .pipe-snapshot div:last-child { min-height: 6.5rem; border: 1px solid var(--line); border-radius: 0; }
      .pipe-snapshot div:first-child { border-radius: 15px 0 0 0; }
      .pipe-snapshot div:nth-child(2) { border-radius: 0 15px 0 0; }
      .pipe-snapshot div:nth-child(3) { border-radius: 0 0 0 15px; }
      .pipe-snapshot div:last-child { border-radius: 0 0 15px 0; }
      .pipe-stage { grid-template-columns: 3rem minmax(0,1fr); }
      .pipe-stage > code { grid-column: 2; margin: -1.6rem 0 2rem; width: fit-content; }
      .pipe-boundary { grid-template-columns: 1fr; }
      .pipe-layers article { grid-template-columns: 2rem 1fr; }
      .pipe-layers p { grid-column: 2; }
      .pipe-footer { flex-direction: column; }
    }
    @media (prefers-reduced-motion: reduce) { .pipe-hero__path { animation: none; } }
  </style>
</Layout>
