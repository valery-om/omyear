---
import Layout from "../layouts/Layout.astro";

const promises = [
  ["Made from you", "Your real story comes first."],
  ["Made to keep", "A beautiful book to revisit."],
  ["Made with care", "Warm writing, carefully checked."],
  ["Made for reflection", "No fate. No fixed predictions."],
];
const layers = [
  ["01", "Tell us where you are", "Your hopes, questions, routines and turning points set the direction."],
  ["02", "We map the patterns", "Thoughtful calculations uncover themes to explore—not fixed predictions."],
  ["03", "Your book takes shape", "GPT‑5.6 weaves the material into a warm, coherent story for the year."],
  ["04", "You keep the last word", "The result is yours to question, annotate and live in your own way."],
];
---

<Layout
  title="Omyear — your personal year, turned into a book"
  description="A beautiful personal book for the year between birthdays, created from your story and made to return to throughout the year."
  music={false}
  language="en"
>
  <main class="home">
    <header class="home-hero">
      <nav class="home-nav" aria-label="Primary navigation">
        <a href="/" aria-current="page">omyear</a>
        <div><a href="/try">create yours</a><a href="/pipeline">how it works</a><a href="/0811">Maya’s example</a><button id="language-toggle" type="button">RU</button></div>
      </nav>
      <div class="home-orbit" aria-hidden="true"><i></i><i></i><i></i><span></span></div>
      <div class="home-hero__copy">
        <p class="home-kicker">OpenAI Build Week · A book for your personal year</p>
        <h1>Your year,<br /><em>turned into a book.</em></h1>
        <p class="home-lede">A beautiful personal book for the year between birthdays—created from your story, your questions, and the patterns that make you who you are.</p>
        <div class="home-actions">
          <a class="home-button home-button--solid" href="/try">Create your Omyear <span>↗</span></a>
          <a class="home-button" href="/0811">Explore Maya’s <span>→</span></a>
        </div>
      </div>
      <p class="home-side home-side--left">your story · your questions</p>
      <p class="home-side home-side--right">twelve chapters · one year</p>
    </header>

    <section class="home-metrics" aria-label="What makes Omyear personal">
      {promises.map(([title, text]) => <div><strong>{title}</strong><span>{text}</span></div>)}
    </section>

    <section class="home-story">
      <div>
        <p class="home-kicker">made around a real person</p>
        <h2>Not a generic reading.<br />Not a prediction.<br />A book that begins with you.</h2>
      </div>
      <div class="home-story__copy">
        <p>Most generated readings start with a prompt and fill in the blanks. Omyear starts with your actual life: what matters, what is shifting, what you want to protect, and what you are ready to explore.</p>
        <p>Then it brings structure and imagination together—so the result feels intimate without pretending to know your future.</p>
      </div>
    </section>

    <section class="home-layers" aria-label="Omyear information layers">
      {layers.map(([number, title, text]) => <article><span>{number}</span><h3>{title}</h3><p>{text}</p></article>)}
    </section>

    <section class="home-path">
      <p class="home-kicker">from your story to your shelf</p>
      <div class="home-path__flow" aria-label="Pipeline summary">
        <span>your story</span><i>→</i><span>patterns</span><i>→</i><span>thoughtful writing</span><i>→</i><span>careful checks</span><i>→</i><span>your Omyear</span>
      </div>
      <div class="home-path__close">
        <h2>Meet Maya.<br /><em>Her story is fictional. Her Omyear is ready to explore.</em></h2>
        <p>Want to see the whole experience first? Maya’s details were invented for the demo, so you can open every chapter without looking into a real person’s private life.</p>
        <a class="home-button home-button--solid" href="/0811">Explore Maya’s Omyear <span>↗</span></a>
      </div>
    </section>

    <footer class="home-footer"><span>OMYEAR / YOUR YEAR, MADE PERSONAL</span><a href="/pipeline">See how it’s made →</a></footer>
  </main>

  <script>
    const translations = new Map([
      ["create yours","создать свою"],["how it works","как это работает"],["Maya’s example","пример Майи"],
      ["OpenAI Build Week · A book for your personal year","OpenAI Build Week · книга о твоём личном годе"],
      ["Your year,","Твой год,"],["turned into a book.","собранный в книгу."],
      ["A beautiful personal book for the year between birthdays—created from your story, your questions, and the patterns that make you who you are.","Красивая персональная книга на год от дня рождения до дня рождения — о твоей истории, твоих вопросах и особенностях, из которых складываешься ты."],
      ["Create your Omyear","Создать свой Omyear"],["Explore Maya’s","Открыть пример Майи"],
      ["your story · your questions","твоя история · твои вопросы"],["twelve chapters · one year","двенадцать глав · один год"],
      ["Made from you","О тебе"],["Your real story comes first.","Сначала — твоя настоящая история."],
      ["Made to keep","Чтобы сохранить"],["A beautiful book to revisit.","Красивая книга, к которой хочется возвращаться."],
      ["Made with care","С заботой"],["Warm writing, carefully checked.","Тёплый текст, который проходит проверку."],
      ["Made for reflection","Для размышлений"],["No fate. No fixed predictions.","Без судьбоносных обещаний и жёстких прогнозов."],
      ["made around a real person","начинается с живого человека"],
      ["Not a generic reading.","Не шаблонный разбор."],["Not a prediction.","Не предсказание."],["A book that begins with you.","Книга, которая начинается с тебя."],
      ["Most generated readings start with a prompt and fill in the blanks. Omyear starts with your actual life: what matters, what is shifting, what you want to protect, and what you are ready to explore.","Большинство сгенерированных разборов начинаются с промпта и заполняют пустоты. Omyear начинается с твоей настоящей жизни: с того, что для тебя важно, что меняется, что хочется сохранить и что ты готова исследовать."],
      ["Then it brings structure and imagination together—so the result feels intimate without pretending to know your future.","Затем структура встречается с воображением — и книга получается по-настоящему личной, не притворяясь, будто знает твоё будущее."],
      ["Tell us where you are","Расскажи, где ты сейчас"],["Your hopes, questions, routines and turning points set the direction.","Твои надежды, вопросы, привычки и поворотные моменты задают направление."],
      ["We map the patterns","Мы собираем узор"],["Thoughtful calculations uncover themes to explore—not fixed predictions.","Расчёты помогают увидеть темы для размышления — не выдают жёстких предсказаний."],
      ["Your book takes shape","Книга обретает форму"],["GPT‑5.6 weaves the material into a warm, coherent story for the year.","GPT‑5.6 превращает материал в тёплую и цельную историю на год."],
      ["You keep the last word","Последнее слово остаётся за тобой"],["The result is yours to question, annotate and live in your own way.","Ты можешь спорить с книгой, делать заметки и проживать этот год по-своему."],
      ["from your story to your shelf","от твоей истории до твоей книги"],
      ["your story","твоя история"],["patterns","узор"],["thoughtful writing","бережный текст"],["careful checks","проверка"],["your Omyear","твой Omyear"],
      ["Meet Maya.","Познакомься с Майей."],["Her story is fictional. Her Omyear is ready to explore.","Её история выдумана. Её Omyear уже можно открыть."],
      ["Want to see the whole experience first? Maya’s details were invented for the demo, so you can open every chapter without looking into a real person’s private life.","Хочешь сначала увидеть весь результат? Данные Майи придуманы специально для примера: можно открыть каждую главу, не заглядывая в частную жизнь реального человека."],
      ["Explore Maya’s Omyear","Открыть Omyear Майи"],["OMYEAR / YOUR YEAR, MADE PERSONAL","OMYEAR / ТВОЙ ЛИЧНЫЙ ГОД"],["See how it’s made →","Посмотреть, как это сделано →"]
    ]);
    const requested = new URLSearchParams(location.search).get("lang");
    const language = requested === "ru" || (!requested && localStorage.getItem("omyear:language") === "ru") ? "ru" : "en";
    if (language === "ru") {
      document.documentElement.lang = "ru";
      const walker = document.createTreeWalker(document.querySelector(".home"), NodeFilter.SHOW_TEXT);
      while (walker.nextNode()) {
        const node = walker.currentNode; const key = node.nodeValue.trim();
        if (translations.has(key)) node.nodeValue = node.nodeValue.replace(key, translations.get(key));
      }
    }
    const toggle = document.getElementById("language-toggle");
    toggle.textContent = language === "ru" ? "EN" : "RU";
    toggle.addEventListener("click", () => { const next = language === "ru" ? "en" : "ru"; localStorage.setItem("omyear:language", next); location.href = `/?lang=${next}`; });
  </script>

  <style>
    .home { overflow: hidden; }
    .home-hero { position: relative; min-height: 94svh; display: grid; place-items: center; padding: 6rem 1.4rem 4rem; isolation: isolate; }
    .home-nav { position: absolute; z-index: 4; inset: 1.2rem clamp(1.3rem,5vw,4.5rem) auto; display: flex; justify-content: space-between; padding-bottom: .85rem; border-bottom: 1px solid var(--line); }
    .home-nav > a { color: var(--ink); font: 600 1.05rem/1 var(--font-display); text-decoration: none; }
    .home-nav div { display: flex; gap: 1.4rem; }
    .home-nav div a,.home-nav div button { color: var(--sienna); font-size: .62rem; letter-spacing: .14em; text-decoration: none; text-transform: uppercase; }
    .home-nav div button { padding:0;border:0;background:transparent;cursor:pointer; }
    .home-hero__copy { position: relative; z-index: 2; width: min(53rem,88vw); text-align: center; }
    .home-kicker { margin: 0 0 .9rem; color: var(--terracotta-deep); font-size: .65rem; letter-spacing: .24em; text-transform: uppercase; }
    .home-hero h1 { margin: 0; font: 500 clamp(3.4rem,9vw,7.6rem)/.91 var(--font-display); letter-spacing: -.045em; }
    .home-hero h1 em, .home-path h2 em { color: var(--terracotta); font-weight: 400; }
    .home-lede { max-width: 39rem; margin: 1.7rem auto 0; color: var(--ink-soft); font-size: clamp(1rem,2vw,1.18rem); line-height: 1.65; }
    .home-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: .7rem; margin-top: 1.8rem; }
    .home-button { display: inline-flex; align-items: center; gap: .75rem; padding: .8rem 1.2rem; border: 1px solid var(--line-strong); border-radius: 999px; color: var(--ink); font-size: .84rem; line-height: 1; text-decoration: none; transition: transform .2s ease,background .2s ease; }
    .home-button:hover { transform: translateY(-2px); background: var(--paper); }
    .home-button--solid { border-color: var(--terracotta); background: var(--terracotta); color: var(--paper); }
    .home-button--solid:hover { background: var(--terracotta-deep); }
    .home-orbit { position: absolute; z-index: -1; width: min(82vw,52rem); aspect-ratio: 1; left: 50%; top: 48%; transform: translate(-50%,-50%); }
    .home-orbit i { position: absolute; inset: 10%; border: 1px solid rgba(154,106,69,.18); border-radius: 50%; animation: orbit 80s linear infinite; }
    .home-orbit i:nth-child(2) { inset: 20% 2%; transform: rotate(41deg); animation-direction: reverse; }
    .home-orbit i:nth-child(3) { inset: 4% 24%; transform: rotate(73deg); animation-duration: 65s; }
    .home-orbit i::after { content: ""; position: absolute; top: 20%; right: 7%; width: .55rem; height: .55rem; border-radius: 50%; background: var(--terracotta); box-shadow: 0 0 0 6px rgba(194,107,67,.11); }
    .home-orbit span { position: absolute; inset: 36%; border-radius: 50%; background: radial-gradient(circle at 42% 36%,var(--sun-glow),var(--sun)); box-shadow: 0 0 9rem 4rem rgba(241,188,106,.34); }
    @keyframes orbit { to { transform: rotate(360deg); } }
    .home-side { position: absolute; top: 50%; margin: 0; color: var(--sienna); font-size: .54rem; letter-spacing: .24em; text-transform: uppercase; writing-mode: vertical-rl; }
    .home-side--left { left: 1.5rem; transform: rotate(180deg); }
    .home-side--right { right: 1.5rem; }
    .home-metrics { display: grid; grid-template-columns: repeat(4,1fr); max-width: 70rem; margin: 0 auto; padding: 0 1.3rem 6rem; }
    .home-metrics div { min-height: 9.5rem; padding: 1.35rem; border: 1px solid var(--line); border-right: 0; background: rgba(251,244,230,.6); display: flex; flex-direction: column; justify-content: flex-end; }
    .home-metrics div:first-child { border-radius: 18px 0 0 18px; }
    .home-metrics div:last-child { border-right: 1px solid var(--line); border-radius: 0 18px 18px 0; }
    .home-metrics strong { display: block; color: var(--terracotta-deep); font: 500 clamp(1.25rem,2vw,1.6rem)/1.08 var(--font-display); }
    .home-metrics span { display: block; margin-top: .75rem; color: var(--sienna); font-size: .76rem; line-height: 1.45; }
    .home-story { display: grid; grid-template-columns: 1.15fr .85fr; gap: clamp(2rem,8vw,7rem); max-width: 70rem; margin: 0 auto; padding: 6rem 1.3rem 4rem; border-top: 1px solid var(--line); }
    .home-story h2, .home-path h2 { margin: 0; font: 500 clamp(2.3rem,5.5vw,4.2rem)/1.04 var(--font-display); letter-spacing: -.025em; }
    .home-story__copy { padding-top: 1.8rem; }
    .home-story__copy p { color: var(--ink-soft); font-size: .98rem; line-height: 1.65; }
    .home-layers { display: grid; grid-template-columns: repeat(4,1fr); max-width: 70rem; margin: 0 auto; padding: 0 1.3rem 7rem; }
    .home-layers article { min-height: 16rem; padding: 1.4rem; border: 1px solid var(--line); border-right: 0; display: flex; flex-direction: column; background: rgba(251,244,230,.42); }
    .home-layers article:last-child { border-right: 1px solid var(--line); }
    .home-layers span { color: var(--gold); font: 600 .75rem/1 var(--font-display); }
    .home-layers h3 { margin: auto 0 .55rem; font: 600 1.35rem/1.15 var(--font-display); }
    .home-layers p { margin: 0; color: var(--ink-soft); font-size: .82rem; line-height: 1.5; }
    .home-path { max-width: calc(70rem - 2.6rem); margin: 0 auto 6rem; padding: clamp(2rem,6vw,4.5rem); border: 1px solid var(--line); border-radius: 26px; background: var(--paper); }
    .home-path__flow { display: flex; flex-wrap: wrap; align-items: center; gap: .55rem; padding-bottom: 2.4rem; border-bottom: 1px solid var(--line); }
    .home-path__flow span { padding: .45rem .7rem; border: 1px solid var(--line); border-radius: 999px; color: var(--terracotta-deep); font-size: .67rem; letter-spacing: .08em; text-transform: uppercase; }
    .home-path__flow i { color: var(--gold); font-style: normal; }
    .home-path__close { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem 3rem; align-items: end; padding-top: 2.8rem; }
    .home-path__close p { margin: 0; color: var(--ink-soft); font-size: .9rem; line-height: 1.6; }
    .home-path__close .home-button { grid-column: 2; width: fit-content; }
    .home-footer { display: flex; justify-content: space-between; gap: 1rem; padding: 1.5rem clamp(1.3rem,5vw,4.5rem); border-top: 1px solid var(--line); color: var(--sienna); font-size: .58rem; letter-spacing: .13em; }
    .home-footer a { color: var(--terracotta-deep); }
    @media (max-width:720px) {
      .home-nav div { gap: 0; } .home-nav div a { display: none; } .home-nav div button { font-size: .58rem; } .home-side { display:none; } .home-hero__copy { width:100%; } .home-hero h1 { font-size:clamp(2.7rem,11.5vw,3.3rem); }
      .home-metrics { grid-template-columns:repeat(2,1fr); }
      .home-metrics div,.home-metrics div:first-child,.home-metrics div:last-child { min-height:6.5rem; border:1px solid var(--line); border-radius:0; }
      .home-metrics div:first-child { border-radius:15px 0 0 0; } .home-metrics div:nth-child(2) { border-radius:0 15px 0 0; } .home-metrics div:nth-child(3) { border-radius:0 0 0 15px; } .home-metrics div:last-child { border-radius:0 0 15px 0; }
      .home-story,.home-path__close { grid-template-columns:1fr; } .home-layers { grid-template-columns:1fr 1fr; } .home-layers article:nth-child(2) { border-right:1px solid var(--line); } .home-layers article { min-height:12rem; } .home-path__close .home-button { grid-column:1; } .home-footer { flex-direction:column; }
    }
    @media (prefers-reduced-motion:reduce) { .home-orbit i { animation:none; } }
  </style>
</Layout>
