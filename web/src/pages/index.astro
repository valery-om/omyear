---
import Layout from "../layouts/Layout.astro";

const promises = [
  ["Made from you", "Your real story comes first."],
  ["Made to keep", "A beautiful book to revisit."],
  ["Made with care", "Warm writing, carefully checked."],
  ["Made for reflection", "No fate. No fixed predictions."],
];
const layers = [
  ["01", "Tell us where you are", "Your hopes, questions, routines and turning points set the direction."],
  ["02", "We map the patterns", "Thoughtful calculations uncover themes to explore—not fixed predictions."],
  ["03", "Your book takes shape", "GPT‑5.6 weaves the material into a warm, coherent story for the year."],
  ["04", "You keep the last word", "The result is yours to question, annotate and live in your own way."],
];
const systems = [
  ["01", "Numerology", "Turns dates and names into number patterns—a compact language for cycles, priorities, and questions."],
  ["02", "22-Arcana Matrix", "Maps birth-date calculations onto 22 symbolic archetypes, opening questions about strengths, tensions, and choice."],
  ["03", "Astrology", "Uses natal and solar-return charts to frame the year’s themes and rhythm as symbolic weather—not a forecast."],
  ["04", "Human Design", "Combines calculated planetary activations into prompts about decision-making, energy, and how you meet the world."],
  ["05", "Astrocartography", "Maps calculated planetary lines onto places, opening questions about context and perspective—not travel advice or a promise of outcomes."],
];
---

<Layout
  title="Omyear — your personal year, turned into a book"
  description="A beautiful personal book for the year between birthdays, created from your story and made to return to throughout the year."
  music={false}
  language="en"
>
  <main class="home">
    <header class="home-hero">
      <nav class="home-nav" aria-label="Primary navigation">
        <a href="/" aria-current="page">omyear</a>
        <div><a href="/try">create yours</a><a href="/pipeline">how it works</a><a href="/0811">Maya’s example</a><button id="language-toggle" type="button">RU</button></div>
      </nav>
      <div class="home-orbit" aria-hidden="true"><i></i><i></i><i></i><span></span></div>
      <div class="home-hero__copy">
        <p class="home-kicker">OpenAI Build Week · A book for your personal year</p>
        <h1>Your year,<br /><em>turned into a book.</em></h1>
        <p class="home-lede">A beautiful personal book for the year between birthdays—created from your story, your questions, and the patterns that make you who you are.</p>
        <div class="home-actions">
          <a class="home-button home-button--solid" href="/try">Create your Omyear <span>↗</span></a>
          <a class="home-button" href="/0811">Explore Maya’s <span>→</span></a>
        </div>
      </div>
      <p class="home-side home-side--left">your story · your questions</p>
      <p class="home-side home-side--right">twelve chapters · one year</p>
      <span class="home-scroll-cue" aria-hidden="true"></span>
    </header>

    <section class="home-metrics" aria-label="What makes Omyear personal">
      {promises.map(([title, text], index) => <div data-reveal style={`--rd:${index * 90}ms`}><strong>{title}</strong><span>{text}</span></div>)}
    </section>

    <section class="home-story">
      <div data-reveal>
        <p class="home-kicker">made around a real person</p>
        <h2>Not a generic reading.<br />Not a prediction.<br />A book that begins with you.</h2>
      </div>
      <div class="home-story__copy" data-reveal style="--rd:120ms">
        <p>Most generated readings start with a prompt and fill in the blanks. Omyear starts with your actual life: what matters, what is shifting, what you want to protect, and what you are ready to explore.</p>
        <p>Then it brings structure and imagination together—so the result feels intimate without pretending to know your future.</p>
      </div>
    </section>

    <section id="systems" class="home-systems" aria-labelledby="home-systems-title">
      <div class="home-systems__intro">
        <div data-reveal>
          <p class="home-kicker">Five systems · one book for the year</p>
          <h2 id="home-systems-title">Five ways to see yourself.<br /><em>One book to return to when you need your wings back.</em></h2>
        </div>
        <p data-reveal style="--rd:120ms">Omyear brings numerology, the 22-Arcana Matrix, astrology, Human Design, and astrocartography together with the facts, goals, and questions that matter to you now. Deterministic code calculates each system. GPT‑5.6 weaves only registered results and the context you choose to share into a warm personal book for the year between birthdays—for reflection and encouragement, not prediction.</p>
      </div>

      <div class="home-systems__grid">
        {systems.map(([number, title, text], index) => (
          <article data-reveal style={`--rd:${index * 90}ms`}>
            <span>{number}</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>

      <div class="home-systems__method" aria-label="How Omyear uses the five systems">
        <div data-reveal><strong>Calculated by code</strong><p>Every system is calculated from the information you provide—not invented by the model.</p></div>
        <div data-reveal style="--rd:100ms"><strong>Woven by GPT‑5.6</strong><p>The model finds connections across registered results and your chosen context.</p></div>
        <div data-reveal style="--rd:200ms"><strong>Checked against sources</strong><p>Generated claims are verified before they become part of the book.</p></div>
      </div>
      <p class="home-systems__note" data-reveal>Made for reflection, encouragement, and agency—not prediction or instruction.</p>
    </section>

    <section class="home-layers" aria-label="Omyear information layers">
      {layers.map(([number, title, text], index) => <article data-reveal style={`--rd:${index * 90}ms`}><span>{number}</span><h3>{title}</h3><p>{text}</p></article>)}
    </section>

    <section class="home-path">
      <p class="home-kicker" data-reveal>from your story to your shelf</p>
      <div class="home-path__flow" aria-label="Pipeline summary" data-reveal style="--rd:80ms">
        <span>your story</span><i>→</i><span>patterns</span><i>→</i><span>thoughtful writing</span><i>→</i><span>careful checks</span><i>→</i><span>your Omyear</span>
      </div>
      <div class="home-path__close">
        <h2 data-reveal>Meet Maya.<br /><em>Her story is fictional. Her Omyear is ready to explore.</em></h2>
        <p data-reveal style="--rd:120ms">Want to see the whole experience first? Maya’s details were invented for the demo, so you can open every chapter without looking into a real person’s private life.</p>
        <a class="home-button home-button--solid" href="/0811" data-reveal style="--rd:220ms">Explore Maya’s Omyear <span>↗</span></a>
      </div>
    </section>

    <section id="built-with-codex" class="home-build" aria-labelledby="home-build-title">
      <div class="home-build__halo" aria-hidden="true"><i></i><i></i><span></span></div>
      <div class="home-build__intro">
        <div data-reveal>
          <p class="home-kicker">Built with Codex · bounded with care</p>
          <h2 id="home-build-title">A handmade idea,<br /><em>made repeatable.</em></h2>
        </div>
        <p data-reveal style="--rd:120ms">The first Omyear books were made by hand. During Build Week, Codex helped turn that craft into a working bilingual product—without giving the model permission to invent a life.</p>
      </div>

      <div class="home-build__roles" aria-label="How Codex, GPT-5.6, and human judgment work together">
        <article data-reveal>
          <span>01</span>
          <p class="home-build__label">implementation partner</p>
          <h3>Codex builds the system</h3>
          <p>It helped audit the handmade prototype and implement the questionnaire, calculation pipeline, schemas, verification, tests, responsive interface, and deployment.</p>
        </article>
        <article data-reveal style="--rd:100ms">
          <span>02</span>
          <p class="home-build__label">bounded editorial intelligence</p>
          <h3>GPT‑5.6 writes within evidence</h3>
          <p>It receives registered facts and calculated sources in a strict schema. It connects the material; it does not calculate, approve, or publish.</p>
        </article>
        <article data-reveal style="--rd:200ms">
          <span>03</span>
          <p class="home-build__label">the last word</p>
          <h3>Human judgment closes the loop</h3>
          <p>The founder sets the product boundaries and tone. A person reviews the result before any book is delivered.</p>
        </article>
      </div>

      <p class="home-build__flow" data-reveal style="--rd:260ms">
        <span>human direction</span><i>→</i><span>Codex implementation</span><i>→</i><span>deterministic calculation</span><i>→</i><span>GPT‑5.6 synthesis</span><i>→</i><span>verification</span><i>→</i><span>human review</span>
      </p>
    </section>

    <footer class="home-footer" data-reveal><span>OMYEAR / YOUR YEAR, MADE PERSONAL</span><a href="/pipeline">See how it’s made →</a></footer>
  </main>

  <script>
    const translations = new Map([
      ["create yours","создать свою"],["how it works","как это работает"],["Maya’s example","пример Майи"],
      ["OpenAI Build Week · A book for your personal year","OpenAI Build Week · книга о твоём личном годе"],
      ["Your year,","Твой год,"],["turned into a book.","собранный в книгу."],
      ["A beautiful personal book for the year between birthdays—created from your story, your questions, and the patterns that make you who you are.","Красивая персональная книга на год от дня рождения до дня рождения — о твоей истории, твоих вопросах и особенностях, из которых складываешься ты."],
      ["Create your Omyear","Создать свой Omyear"],["Explore Maya’s","Открыть пример Майи"],
      ["your story · your questions","твоя история · твои вопросы"],["twelve chapters · one year","двенадцать глав · один год"],
      ["Made from you","О тебе"],["Your real story comes first.","Сначала — твоя настоящая история."],
      ["Made to keep","Чтобы сохранить"],["A beautiful book to revisit.","Красивая книга, к которой хочется возвращаться."],
      ["Made with care","С заботой"],["Warm writing, carefully checked.","Тёплый текст, который проходит проверку."],
      ["Made for reflection","Для размышлений"],["No fate. No fixed predictions.","Без судьбоносных обещаний и жёстких прогнозов."],
      ["made around a real person","начинается с живого человека"],
      ["Not a generic reading.","Не шаблонный разбор."],["Not a prediction.","Не предсказание."],["A book that begins with you.","Книга, которая начинается с тебя."],
      ["Most generated readings start with a prompt and fill in the blanks. Omyear starts with your actual life: what matters, what is shifting, what you want to protect, and what you are ready to explore.","Большинство сгенерированных разборов начинаются с промпта и заполняют пустоты. Omyear начинается с твоей настоящей жизни: с того, что для тебя важно, что меняется, что хочется сохранить и что ты готова исследовать."],
      ["Then it brings structure and imagination together—so the result feels intimate without pretending to know your future.","Затем структура встречается с воображением — и книга получается по-настоящему личной, не притворяясь, будто знает твоё будущее."],
      ["Five systems · one book for the year","Пять систем · одна книга на весь год"],
      ["Five ways to see yourself.","Пять способов увидеть себя."],["One book to return to when you need your wings back.","Одна книга, к которой можно вернуться, когда нужно снова расправить крылья."],
      ["Omyear brings numerology, the 22-Arcana Matrix, astrology, Human Design, and astrocartography together with the facts, goals, and questions that matter to you now. Deterministic code calculates each system. GPT‑5.6 weaves only registered results and the context you choose to share into a warm personal book for the year between birthdays—for reflection and encouragement, not prediction.","Omyear объединяет нумерологию, Матрицу 22 арканов, астрологию, Дизайн человека и астрокартографию с реальными фактами о тебе, твоими целями и вопросами, которые важны сейчас. Код детерминированно рассчитывает каждую систему. GPT‑5.6 соединяет только зарегистрированные результаты и контекст, которым ты решила поделиться, в тёплую персональную книгу на год между днями рождения — для рефлексии и поддержки, а не для предсказаний."],
      ["Numerology","Нумерология"],["Turns dates and names into number patterns—a compact language for cycles, priorities, and questions.","Переводит даты и имя в числовые темы — компактный язык для размышления о циклах, приоритетах и вопросах."],
      ["22-Arcana Matrix","Матрица 22 арканов"],["Maps birth-date calculations onto 22 symbolic archetypes, opening questions about strengths, tensions, and choice.","Соотносит расчёты по дате рождения с 22 символическими архетипами и предлагает вопросы о сильных сторонах, напряжениях и выборе."],
      ["Astrology","Астрология"],["Uses natal and solar-return charts to frame the year’s themes and rhythm as symbolic weather—not a forecast.","Использует натальную карту и соляр, чтобы описать темы и ритм года как символическую погоду, а не прогноз."],
      ["Human Design","Дизайн человека"],["Combines calculated planetary activations into prompts about decision-making, energy, and how you meet the world.","Соединяет рассчитанные планетарные активации в вопросы о принятии решений, энергии и взаимодействии с миром."],
      ["Astrocartography","Астрокартография"],["Maps calculated planetary lines onto places, opening questions about context and perspective—not travel advice or a promise of outcomes.","Наносит рассчитанные планетарные линии на карту мест и предлагает вопросы о контексте и перспективе — без рекомендаций по поездкам и обещаний результата."],
      ["Calculated by code","Рассчитано кодом"],["Every system is calculated from the information you provide—not invented by the model.","Каждая система рассчитывается по данным, которые ты предоставляешь, — модель ничего не придумывает."],
      ["Woven by GPT‑5.6","Соединено GPT‑5.6"],["The model finds connections across registered results and your chosen context.","Модель находит связи между зарегистрированными результатами и выбранным тобой контекстом."],
      ["Checked against sources","Проверено по источникам"],["Generated claims are verified before they become part of the book.","Сгенерированные утверждения проходят проверку, прежде чем стать частью книги."],
      ["Made for reflection, encouragement, and agency—not prediction or instruction.","Создано для рефлексии, поддержки и свободы выбора — не для предсказаний или инструкций."],
      ["Tell us where you are","Расскажи, где ты сейчас"],["Your hopes, questions, routines and turning points set the direction.","Твои надежды, вопросы, привычки и поворотные моменты задают направление."],
      ["We map the patterns","Мы собираем узор"],["Thoughtful calculations uncover themes to explore—not fixed predictions.","Расчёты помогают увидеть темы для размышления — не выдают жёстких предсказаний."],
      ["Your book takes shape","Книга обретает форму"],["GPT‑5.6 weaves the material into a warm, coherent story for the year.","GPT‑5.6 превращает материал в тёплую и цельную историю на год."],
      ["You keep the last word","Последнее слово остаётся за тобой"],["The result is yours to question, annotate and live in your own way.","Ты можешь спорить с книгой, делать заметки и проживать этот год по-своему."],
      ["from your story to your shelf","от твоей истории до твоей книги"],
      ["your story","твоя история"],["patterns","узор"],["thoughtful writing","бережный текст"],["careful checks","проверка"],["your Omyear","твой Omyear"],
      ["Meet Maya.","Познакомься с Майей."],["Her story is fictional. Her Omyear is ready to explore.","Её история выдумана. Её Omyear уже можно открыть."],
      ["Want to see the whole experience first? Maya’s details were invented for the demo, so you can open every chapter without looking into a real person’s private life.","Хочешь сначала увидеть весь результат? Данные Майи придуманы специально для примера: можно открыть каждую главу, не заглядывая в частную жизнь реального человека."],
      ["Explore Maya’s Omyear","Открыть Omyear Майи"],
      ["Built with Codex · bounded with care","Создано с Codex · с бережными границами"],
      ["A handmade idea,","Ручная идея,"],["made repeatable.","ставшая системой."],
      ["The first Omyear books were made by hand. During Build Week, Codex helped turn that craft into a working bilingual product—without giving the model permission to invent a life.","Первые книги Omyear создавались вручную. Во время Build Week Codex помог превратить это ремесло в работающий двуязычный продукт — не давая модели права выдумывать жизнь человека."],
      ["implementation partner","партнёр по реализации"],["Codex builds the system","Codex строит систему"],["It helped audit the handmade prototype and implement the questionnaire, calculation pipeline, schemas, verification, tests, responsive interface, and deployment.","Он помог провести аудит ручного прототипа и реализовать анкету, конвейер расчётов, схемы, проверку, тесты, адаптивный интерфейс и деплой."],
      ["bounded editorial intelligence","редакторский интеллект в границах"],["GPT‑5.6 writes within evidence","GPT‑5.6 пишет только по данным"],["It receives registered facts and calculated sources in a strict schema. It connects the material; it does not calculate, approve, or publish.","Он получает зарегистрированные факты и рассчитанные источники в строгой схеме. Он соединяет материал, но не рассчитывает, не утверждает и не публикует."],
      ["the last word","последнее слово"],["Human judgment closes the loop","Человек завершает работу"],["The founder sets the product boundaries and tone. A person reviews the result before any book is delivered.","Фаундер задаёт границы продукта и интонацию. Перед передачей книги человеку результат проходит человеческую проверку."],
      ["human direction","человеческий замысел"],["Codex implementation","реализация с Codex"],["deterministic calculation","детерминированный расчёт"],["GPT‑5.6 synthesis","синтез GPT‑5.6"],["verification","проверка"],["human review","человеческая редактура"],
      ["OMYEAR / YOUR YEAR, MADE PERSONAL","OMYEAR / ТВОЙ ЛИЧНЫЙ ГОД"],["See how it’s made →","Посмотреть, как это сделано →"]
    ]);
    const requested = new URLSearchParams(location.search).get("lang");
    const language = requested === "ru" || (!requested && localStorage.getItem("omyear:language") === "ru") ? "ru" : "en";
    if (language === "ru") {
      document.documentElement.lang = "ru";
      const walker = document.createTreeWalker(document.querySelector(".home"), NodeFilter.SHOW_TEXT);
      while (walker.nextNode()) {
        const node = walker.currentNode; const key = node.nodeValue.trim();
        if (translations.has(key)) node.nodeValue = node.nodeValue.replace(key, translations.get(key));
      }
      document.querySelector(".home-systems__method")?.setAttribute("aria-label", "Как Omyear использует пять систем");
      document.querySelector(".home-build__roles")?.setAttribute("aria-label", "Как Codex, GPT-5.6 и человеческая редактура работают вместе");
    }
    const toggle = document.getElementById("language-toggle");
    toggle.textContent = language === "ru" ? "EN" : "RU";
    toggle.addEventListener("click", () => { const next = language === "ru" ? "en" : "ru"; localStorage.setItem("omyear:language", next); location.href = `/?lang=${next}`; });
    const home = document.querySelector(".home");
    requestAnimationFrame(() => requestAnimationFrame(() => home?.classList.add("is-ready")));
  </script>

  <style>
    .home { overflow: hidden; }
    .home-hero { position: relative; min-height: 94svh; display: grid; place-items: center; padding: 6rem 1.4rem 4rem; isolation: isolate; }
    .home-nav { position: absolute; z-index: 4; inset: 1.2rem clamp(1.3rem,5vw,4.5rem) auto; display: flex; justify-content: space-between; padding-bottom: .85rem; border-bottom: 1px solid var(--line); transition: opacity .8s ease,transform 1s cubic-bezier(.2,.75,.2,1); }
    .home-nav > a { color: var(--ink); font: 600 1.05rem/1 var(--font-display); text-decoration: none; }
    .home-nav div { display: flex; gap: 1.4rem; }
    .home-nav div a,.home-nav div button { color: var(--sienna); font-size: .62rem; letter-spacing: .14em; text-decoration: none; text-transform: uppercase; background-image:linear-gradient(var(--terracotta),var(--terracotta));background-repeat:no-repeat;background-position:0 100%;background-size:0 1px;transition:color .25s ease,background-size .35s cubic-bezier(.2,.75,.2,1); }
    .home-nav div button { padding:0;border:0;background-color:transparent;cursor:pointer; }
    .home-hero__copy { position: relative; z-index: 2; width: min(53rem,88vw); text-align: center; }
    .home-kicker { margin: 0 0 .9rem; color: var(--terracotta-deep); font-size: .65rem; letter-spacing: .24em; text-transform: uppercase; }
    .home-hero__copy > * { clip-path:inset(0 0 0 0);transition: opacity .9s ease,transform 1.05s cubic-bezier(.2,.78,.2,1),clip-path 1.05s cubic-bezier(.2,.78,.2,1); }
    .home-hero h1 { margin: 0; font: 500 clamp(3.4rem,9vw,7.6rem)/.91 var(--font-display); letter-spacing: -.045em; transition-delay:.16s; }
    .home-hero h1 em, .home-path h2 em { color: var(--terracotta); font-weight: 400; }
    .home-lede { max-width: 39rem; margin: 1.7rem auto 0; color: var(--ink-soft); font-size: clamp(1rem,2vw,1.18rem); line-height: 1.65; transition-delay:.34s; }
    .home-actions { display: flex; justify-content: center; flex-wrap: wrap; gap: .7rem; margin-top: 1.8rem; transition-delay:.5s; }
    .home-button { display: inline-flex; align-items: center; gap: .75rem; padding: .8rem 1.2rem; border: 1px solid var(--line-strong); border-radius: 999px; color: var(--ink); font-size: .84rem; line-height: 1; text-decoration: none; transition: transform .3s cubic-bezier(.2,.8,.2,1),background .3s ease,box-shadow .3s ease; }
    .home-button span { display:inline-block;transition:transform .3s cubic-bezier(.2,.8,.2,1); }
    .home-button:hover { transform: translateY(-3px); background: var(--paper); box-shadow:0 14px 30px -20px rgba(91,50,30,.5); }
    .home-button:hover span { transform:translate(3px,-2px); }
    .home-button--solid { border-color: var(--terracotta); background: var(--terracotta); color: var(--paper); }
    .home-button--solid:hover { background: var(--terracotta-deep); }
    .home-orbit { position: absolute; z-index: -1; width: min(82vw,52rem); aspect-ratio: 1; left: 50%; top: 48%; transform: translate(-50%,-50%) scale(1); opacity:1; transition:opacity 1.4s ease,transform 1.8s cubic-bezier(.18,.82,.22,1); }
    .home-orbit i { --orbit-start:0deg; position: absolute; inset: 10%; border: 1px solid rgba(154,106,69,.18); border-radius: 50%; transform:rotate(var(--orbit-start)); animation: orbit 42s linear infinite; transition:opacity 1.2s ease; }
    .home-orbit i:nth-child(2) { --orbit-start:41deg; inset: 20% 2%; animation-direction: reverse; animation-duration:34s; }
    .home-orbit i:nth-child(3) { --orbit-start:73deg; inset: 4% 24%; animation-duration:48s; }
    .home-orbit i::after { content: ""; position: absolute; top: 20%; right: 7%; width: .55rem; height: .55rem; border-radius: 50%; background: var(--terracotta); box-shadow: 0 0 0 6px rgba(194,107,67,.11); }
