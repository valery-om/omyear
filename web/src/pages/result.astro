---
import Layout from "../layouts/Layout.astro";
import mayaDemo from "../data/people/maya-demo.json";

const demoData = JSON.stringify(mayaDemo).replaceAll("<", "\\u003c");
---

<Layout
  title="Your Omyear — private browser result"
  description="A private, source-linked personal year book generated from your permitted material."
  music={false}
  language="en"
  styleName="warm-sunset"
  experience="editorial-atlas"
>
  <main class="result-shell">
    <nav id="result-nav" class="result-nav" aria-label="Book controls">
      <a id="home-link" class="result-brand" href="/"><span aria-hidden="true"></span>omyear</a>
      <div class="result-tools">
        <div class="language-switch" aria-label="Language">
          <a id="language-ru" href="/try/?lang=ru" hreflang="ru">RU</a>
          <a id="language-en" href="/try/?lang=en" hreflang="en">EN</a>
        </div>
        <details id="contents" class="contents">
          <summary id="contents-label">Contents</summary>
          <div id="contents-list" class="contents-list"></div>
        </details>
        <button id="print" type="button">Print / PDF</button>
        <button id="clear" class="clear-book" type="button">Clear this book</button>
      </div>
    </nav>
    <div id="empty" class="empty" hidden><p>There is no generated book in this tab.</p><h1>Start with your<br /><em>own material.</em></h1><a href="/try">Create an Omyear →</a></div>
    <article id="book" class="book generated-book" hidden></article>
  </main>

  <script id="demo-book" type="application/json" set:html={demoData}></script>

  <script>
    const COPY = {
      en:{print:"Print / PDF",clear:"Clear",contents:"Contents",cover:"Cover",empty:"There is no generated book in this tab.",emptyTitle:"Start with your own material.",start:"Create an Omyear →",private:"private browser result",numbers:"your numbers",matrix:"your symbolic portrait",nature:"your nature",year:"the year’s question",months:"twelve chapters",synergy:"the combined lens",places:"symbolic geography",traps:"watch with care",days:"the first twelve days",manifest:"a compact compass",letter:"leave a trace",sources:"Source ledger",sourcesIntro:"Every interpretation can be traced to a fact you shared or a result calculated by code.",sourceRecords:"source records",cited:"sources cited",errors:"source-link errors",review:"human review flags",method:"Method",status:"Verification",bookMap:"Your atlas of the year",mapIntro:"Read in order or open the chapter you need.",now:"now",scroll:"scroll to begin",practice:"Chapter practice.",deleteConfirm:"Remove this generated book from this browser tab?",switchToRu:"Create a new Russian edition",switchToEn:"Create a new English edition"},
      ru:{print:"Печать / PDF",clear:"Удалить",contents:"Оглавление",cover:"Обложка",empty:"В этой вкладке нет созданной книги.",emptyTitle:"Начни со своего материала.",start:"Создать Omyear →",private:"приватный результат в браузере",numbers:"твои числа",matrix:"твой символический портрет",nature:"твоя природа",year:"вопрос года",months:"двенадцать глав",synergy:"общая оптика",places:"символическая география",traps:"на что смотреть бережно",days:"первые двенадцать дней",manifest:"короткий компас",letter:"оставить след",sources:"Реестр источников",sourcesIntro:"Каждую интерпретацию можно связать с фактом, которым ты поделилась, или результатом, рассчитанным кодом.",sourceRecords:"источников",cited:"источников процитировано",errors:"ошибок связей",review:"флагов для редактора",method:"Метод",status:"Проверка",bookMap:"Твой атлас года",mapIntro:"Можно читать по порядку или открыть нужную главу.",now:"сейчас",scroll:"листай вниз",practice:"Практика главы.",deleteConfirm:"Удалить созданную книгу из этой вкладки браузера?",switchToRu:"Создать новую книгу на русском",switchToEn:"Создать новую книгу на английском"}
    };
    const stored = sessionStorage.getItem("omyear:book");
    const demo = new URLSearchParams(location.search).get("demo") === "maya" ? JSON.parse(document.getElementById("demo-book").textContent) : null;
    const bookRoot = document.getElementById("book"); const empty = document.getElementById("empty");
    const make = (tag,className,text) => { const node=document.createElement(tag); if(className) node.className=className; if(text!==undefined&&text!==null) node.textContent=String(text); return node; };
    const appendTextItems = (parent,items,className="prose") => { const wrap=make("div",className); wrap.dataset.reveal=""; (items||[]).filter(Boolean).forEach((text)=>wrap.append(make("p","lead",typeof text==="string"?text:text.text))); parent.append(wrap); return wrap; };
    function sunMark() { const holder=make("span","sun-mark"); holder.innerHTML='<svg width="30" height="30" viewBox="0 0 32 32" aria-hidden="true"><circle cx="16" cy="16" r="5.2" fill="#E0954E"/><g stroke="#C26B43" stroke-width="1.2" stroke-linecap="round"><path d="M16 2v5M16 25v5M2 16h5M25 16h5M6.1 6.1l3.6 3.6M22.3 22.3l3.6 3.6M25.9 6.1l-3.6 3.6M9.7 22.3l-3.6 3.6"/></g></svg>'; return holder; }
    function section(kicker,title,intro,className="") { const node=make("section",`section ${className}`); const head=make("div","section__head"); head.dataset.reveal=""; head.append(sunMark(),make("p","section-kicker",kicker),make("h2","section__title",title)); if(intro) head.append(make("p","section__intro",intro)); node.append(head); return node; }
    function cards(parent,items,render,className="cards") { const grid=make("div",className); grid.dataset.reveal=""; (items||[]).forEach((item,index)=>{const card=render(item,index);card.style.setProperty("--rd",`${(index%4)*80}ms`);grid.append(card)}); parent.append(grid); return grid; }
    function localizeControls(lang) {
      const c=COPY[lang];
      const ru=document.getElementById("language-ru"); const en=document.getElementById("language-en");
      document.getElementById("print").textContent=c.print; document.getElementById("clear").textContent=c.clear; document.getElementById("contents-label").textContent=c.contents;
      document.getElementById("home-link").href=`/?lang=${lang}`;
      ru.title=c.switchToRu; en.title=c.switchToEn;
      [ru,en].forEach((link)=>link.removeAttribute("aria-current"));
      document.getElementById(`language-${lang}`).setAttribute("aria-current","page");
    }
    function buildContents(book,lang) {
      const c=COPY[lang]; const list=document.getElementById("contents-list"); list.replaceChildren();
      const cover=make("a","",c.cover); cover.href="#book-cover"; list.append(cover);
      bookRoot.querySelectorAll(".book-body > .section").forEach((item,index)=>{if(!item.id)item.id=`chapter-${index+1}`;const link=make("a","",item.querySelector("h2")?.textContent||String(index+1));link.href=`#${item.id}`;list.append(link)});
      list.querySelectorAll("a").forEach((link)=>link.addEventListener("click",()=>document.getElementById("contents").removeAttribute("open")));
    }
    function initGeneratedReveals(root) {
      const elements=[...root.querySelectorAll("[data-reveal]")];
      const show=(element)=>{element.removeAttribute("data-reveal");element.classList.remove("is-visible");element.style.removeProperty("--rd")};
      if(matchMedia("(prefers-reduced-motion: reduce)").matches||!("IntersectionObserver" in window)){elements.forEach(show);return}
      const observer=new IntersectionObserver((entries)=>entries.forEach((entry)=>{if(!entry.isIntersecting)return;observer.unobserve(entry.target);entry.target.classList.add("is-visible");setTimeout(()=>show(entry.target),2000)}),{rootMargin:"0px 0px -9% 0px",threshold:.05});
      elements.forEach((element)=>observer.observe(element));
    }
    function renderBook(book) {
      const lang=book.person.language==="ru"?"ru":"en"; const c=COPY[lang]; document.documentElement.lang=lang;
      document.title=lang==="ru"?`${book.person.name} — личный Omyear`:`${book.person.name} — personal Omyear`; localizeControls(lang);
      const hero=make("header","hero"); hero.id="book-cover";
      const sky=make("div","hero__sky"); sky.setAttribute("aria-hidden","true"); sky.append(make("div","hero__rays"),make("div","hero__sun")); const signal=make("div","signal-field"); signal.innerHTML='<span class="signal-orbit signal-orbit--one"></span><span class="signal-orbit signal-orbit--two"></span><span class="signal-node signal-node--one"></span><span class="signal-node signal-node--two"></span><span class="signal-node signal-node--three"></span><svg class="signal-wave" viewBox="0 0 1200 180" preserveAspectRatio="none"><path d="M0 116 C150 34 280 146 430 78 C570 14 700 146 846 86 C980 32 1080 70 1200 44"/></svg>';
      signal.append(make("span","signal-field__label signal-field__label--left",lang==="ru"?"оставь только своё":"keep only what feels yours"),make("span","signal-field__label signal-field__label--right",book.person.signalDate)); sky.append(signal); const motes=make("div","hero__motes"); for(let i=0;i<10;i++)motes.append(make("span","hero__mote")); sky.append(motes);
      const inner=make("div","hero__inner"); const monthLabel=new Intl.DateTimeFormat(lang==="ru"?"ru-RU":"en-GB",{month:"long",year:"numeric",timeZone:"UTC"}).format(new Date(`${book.person.startDate}T12:00:00Z`)); const meta=make("div","signal-meta reveal d1");meta.append(make("span","",monthLabel));inner.append(meta,make("p","hero__kicker reveal d1",book.hero.kicker),make("h1","hero__name reveal d2",book.hero.title),make("hr","hero__rule reveal d3"),make("p","hero__sub reveal d3",book.hero.subtitle),make("p","hero__note reveal d4",`${book.person.birthDate} · ${book.person.birthPlace}`),make("p","signal-span reveal d5",book.person.yearSpan)); hero.append(sky,inner,make("span","hero__cue",c.scroll)); bookRoot.append(hero);

      const body=make("main","wrap book-body experience-editorial-atlas"); bookRoot.append(body);
      const chapters=[]; const add=(node,id,title,note)=>{node.id=id;node.dataset.chapter="";node.dataset.chapterTitle=title;body.append(node);chapters.push({id,title,note});};
      const message=section("01",book.message.heading,null,"feature message-section"); const messageBody=appendTextItems(message,book.message.paragraphs,"message__body prose");messageBody.prepend(make("span","message__date",book.person.signalDate));add(message,"opening",book.message.heading,lang==="ru"?"личное письмо":"a personal note");
      const indexSection=make("section","section year-index-section");indexSection.id="year-index";const indexHead=make("div","year-index__head");indexHead.dataset.reveal="";indexHead.append(make("p","",lang==="ru"?"карта книги":"book map"),make("h2","",c.bookMap),make("span","",c.mapIntro));const yearIndex=make("nav","year-index");yearIndex.dataset.reveal="";indexSection.append(indexHead,yearIndex);body.append(indexSection);
      const numbers=section(c.numbers,book.numbers.heading,book.numbers.intro,"numbers-section"); cards(numbers,book.numbers.items,(item)=>{const card=make("article","numcard");card.append(make("div","numcard__val",item.value),make("div",""));card.lastChild.append(make("p","numcard__name",item.name),make("p","numcard__text",item.text));return card;},"numbers"); numbers.append(make("p","synthesis",book.numbers.synthesis)); add(numbers,"numbers",book.numbers.heading,c.numbers);
      const matrix=section(c.matrix,book.matrix.heading,book.matrix.intro,"matrix-section"); cards(matrix,book.matrix.items,(item)=>{const card=make("article","arcana");card.append(make("div","arcana__num",item.arcana),make("div",""));card.lastChild.append(make("span","arcana__name",item.name),make("span","arcana__role",item.role),make("p","arcana__text",item.text));return card;},"arcanas"); matrix.append(make("p","synthesis",book.matrix.synthesis)); add(matrix,"matrix",book.matrix.heading,c.matrix);
      const nature=section(c.nature,book.nature.heading,book.nature.intro,"nature-section");const natureWrap=make("div","nature");cards(natureWrap,book.nature.design,(item)=>{const row=make("article","nature__row");row.append(make("p","nature__label",item.label),make("p","nature__text",item.text));return row;},"nature__rows");natureWrap.append(make("h3","nature__subhead",book.nature.strengthsHeading));const strengths=make("ul","strengths");book.nature.strengths.forEach((item)=>{const li=make("li","strength");li.append(make("span","strength__title",`${item.title}: `),document.createTextNode(item.text));strengths.append(li)});natureWrap.append(strengths);nature.append(natureWrap);add(nature,"nature",book.nature.heading,c.nature);
      const year=section(c.year,book.yearTheme.heading,book.yearTheme.intro,"year-section"); appendTextItems(year,book.yearTheme.paragraphs);add(year,"year",book.yearTheme.heading,c.year);
      const months=section(c.months,book.months.heading,book.months.intro,"months-section");const monthList=make("div","months");book.months.items.forEach((item,index)=>{const detail=make("details","month month--compact");detail.dataset.monthIndex=index;detail.dataset.current=String(index===0);detail.open=index===0;const summary=make("summary","month__summary");const copy=make("span","month__summary-copy");const top=make("span","month__top");top.append(make("span","month__name",item.month),make("span","month__current",c.now));copy.append(top,make("span","month__tags",`${item.topic} · ${item.house}`));summary.append(copy,make("span","month__note",item.note),make("span","month__arrow"));const content=make("div","month__content");content.append(make("p","month__text",item.text));const practice=make("div","month__practice");practice.append(make("span","practice__check","✓"),make("span","practice__text",`${c.practice} ${book.monthPractices[index]}`));content.append(practice);detail.append(summary,content);monthList.append(detail)});months.append(monthList);add(months,"months",book.months.heading,c.months);
      const synergy=section(c.synergy,book.synergy.heading,null,"synergy-section");appendTextItems(synergy,book.synergy.paragraphs);add(synergy,"synergy",book.synergy.heading,c.synergy);
      const places=section(book.places.eyebrow||c.places,book.places.heading,book.places.intro,"feature places-section");
      const compass=make("div","places-compass");compass.dataset.reveal="";
      book.places.compass.forEach((item,index)=>{const card=make("article","places-compass__item");card.style.setProperty("--rd",`${index*80}ms`);const copy=make("div","");copy.append(make("b","",item.label),make("p","",item.text));card.append(make("span","",String(index+1).padStart(2,"0")),copy);compass.append(card)});
      const placeMoment=make("p","places-section__moment",book.places.moment);placeMoment.dataset.reveal="";places.append(compass,placeMoment);appendTextItems(places,book.places.paragraphs);
      const placeList=make("div","places-list");placeList.dataset.reveal="";placeList.append(make("p","places-list__head",book.places.citiesHeading));const placeUl=make("ul","places-list__ul");book.places.cities.forEach((item)=>{const li=make("li","places-list__item");const dot=make("span","places-list__dot");dot.style.background=item.color;li.append(dot,make("span","",`${item.name} · ${item.line} — ${item.text}`));placeUl.append(li)});placeList.append(placeUl);
      const placeMethod=make("p","places-method",book.places.method);placeMethod.dataset.reveal="";const placesSynthesis=make("p","synthesis places-synthesis",book.places.note);placesSynthesis.dataset.reveal="";places.append(placeList,placeMethod,placesSynthesis);add(places,"places",book.places.heading,c.places);
      const traps=section(c.traps,book.traps.heading,book.traps.intro,"traps-section");cards(traps,book.traps.items,(item)=>{const card=make("article","trap");card.append(make("p","trap__title",item.title),make("p","trap__text",item.text),make("p","trap__antidote",item.antidote));return card;},"traps");traps.append(make("p","synthesis",book.traps.closing));add(traps,"traps",book.traps.heading,c.traps);
      const days=section(c.days,book.twelveDays.heading,book.twelveDays.intro,"days-section");cards(days,book.twelveDays.items,(item)=>{const card=make("article","day");card.append(make("span","day__check","✓"),make("div",""));card.lastChild.append(make("span","day__meta",`${item.day} · ${item.date}`),make("h3","day__title",item.title),make("p","day__text",item.text));return card;},"days");add(days,"days",book.twelveDays.heading,c.days);
      const manifest=section(c.manifest,book.manifest.heading,null,"feature manifest-section");appendTextItems(manifest,book.manifest.paragraphs,"manifest__body prose");add(manifest,"manifest",book.manifest.heading,c.manifest);
      const letter=section(c.letter,book.letter.heading,book.letter.intro,"feature letter-section");cards(letter,book.letter.prompts,(item,index)=>{const card=make("article","prompt-card");card.append(make("span","",String(index+1).padStart(2,"0")),make("p","",item));return card;},"letter-prompts");letter.append(make("p","synthesis",book.letter.closing));add(letter,"future-letter",book.letter.heading,c.letter);
      const verification=book.provenance.verification;const provenance=section(c.sources,c.sources,c.sourcesIntro,"provenance-section");const metrics=make("div","source-metrics");[[book.provenance.sourceCount,c.sourceRecords],[verification.referencedClaimCount,c.cited],[verification.invalidSourceIds.length+verification.missingSourcePaths.length+verification.structuralErrors.length,c.errors],[verification.humanReview.flaggedPaths.length,c.review]].forEach(([value,label])=>{const metric=make("div","");metric.append(make("strong","",value),make("span","",label));metrics.append(metric)});provenance.append(metrics);const details=make("details","ledger");details.append(make("summary","",`${c.sources} · ${book.provenance.sourceCount}`));const list=make("div","ledger-list");book.provenance.sourceRecords.forEach((source)=>{const row=make("article","");const id=make("code","",source.id);const sourceBody=make("div","");sourceBody.append(make("h3","",source.label),make("p","",`${c.method}: ${source.method}`));row.append(id,sourceBody);list.append(row)});details.append(list);provenance.append(details,make("p","method",`${c.status}: ${verification.status} · ${book.provenance.generationModel}`));add(provenance,"sources",c.sources,c.sources);
      chapters.forEach((chapter,index)=>{const link=make("a",chapter.id==="places"?"year-index__item--accent":"");link.href=`#${chapter.id}`;link.append(make("span","year-index__number",String(index).padStart(2,"0")),make("span","year-index__text"),make("span","year-index__arrow","↘"));link.children[1].append(make("b","",chapter.title),make("small","",chapter.note));yearIndex.append(link)});
      const footer=make("footer","foot");footer.append(make("p","foot__disc",book.footer.disclaimer),make("p","foot__signoff",book.footer.signoff),make("p","foot__made",lang==="ru"?"Твой год. Твоя книга.":"Your year. Your book."));body.append(footer);
      buildContents(book,lang);
    }
    if (!stored && !demo) { empty.hidden=false; const lang=new URLSearchParams(location.search).get("lang")==="ru"?"ru":"en";const c=COPY[lang];document.documentElement.lang=lang;localizeControls(lang);empty.querySelector("p").textContent=c.empty;empty.querySelector("h1").textContent=c.emptyTitle;empty.querySelector("a").textContent=c.start;empty.querySelector("a").href=`/try/?lang=${lang}`;document.getElementById("print").hidden=true;document.getElementById("clear").hidden=true;document.getElementById("contents").hidden=true; }
    else { try { renderBook(stored ? JSON.parse(stored) : demo); bookRoot.hidden=false; initGeneratedReveals(bookRoot); } catch { sessionStorage.removeItem("omyear:book"); empty.hidden=false; } }
    document.getElementById("print").addEventListener("click",()=>print());
    document.getElementById("clear").addEventListener("click",()=>{const lang=document.documentElement.lang==="ru"?"ru":"en";if(confirm(COPY[lang].deleteConfirm)){sessionStorage.removeItem("omyear:book");location.href=`/try?lang=${lang}`;}});
    document.addEventListener("click",(event)=>{const contents=document.getElementById("contents");if(contents.open&&!contents.contains(event.target))contents.removeAttribute("open")});
    const resultNav=document.getElementById("result-nav");
    const updateResultNav=()=>resultNav.dataset.visible=String(scrollY>innerHeight*.72);
    addEventListener("scroll",updateResultNav,{passive:true});addEventListener("resize",updateResultNav,{passive:true});updateResultNav();
  </script>

  <style is:global>
    .empty[hidden],.book[hidden]{display:none!important}
    .result-shell{max-width:76rem;margin:0 auto;padding:0 1.3rem}.result-nav{position:relative;z-index:5;display:flex;justify-content:space-between;gap:1rem;padding:1.2rem 0;border-bottom:1px solid var(--line)}.result-nav>a{color:var(--ink);font:600 1.05rem/1 var(--font-display);text-decoration:none}.result-nav div{display:flex;gap:.5rem}.result-nav button{border:1px solid var(--line);border-radius:999px;background:transparent;padding:.5rem .75rem;color:var(--sienna);font-size:.62rem;cursor:pointer}.empty{min-height:80svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}.empty p{color:var(--sienna);font-size:.7rem;letter-spacing:.15em;text-transform:uppercase}.empty h1{margin:.5rem 0 1.8rem;font:500 clamp(3rem,8vw,6rem)/.95 var(--font-display)}.empty h1 em{color:var(--terracotta)}.empty a{color:var(--paper);background:var(--terracotta);border-radius:999px;padding:.8rem 1rem;text-decoration:none}.book-hero{position:relative;min-height:88svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;overflow:hidden}.book-hero:before{content:"";position:absolute;width:min(38rem,80vw);aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,var(--sun),transparent 68%);opacity:.6;z-index:-1}.book-hero__kicker,.section-kicker{color:var(--terracotta-deep);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase}.book-hero h1{margin:.3rem 0;font:500 clamp(4rem,12vw,9rem)/.85 var(--font-display);letter-spacing:-.05em}.book-hero__sub{font:italic 400 clamp(1.2rem,3vw,2rem)/1.2 var(--font-display);color:var(--sienna)}.book-hero__note{max-width:35rem;color:var(--ink-soft)}.book-hero__private{position:absolute;bottom:2rem;padding:.45rem .7rem;border:1px solid var(--line);border-radius:999px;color:var(--sienna);font-size:.57rem;letter-spacing:.12em;text-transform:uppercase}.book-section{padding:6rem clamp(0rem,4vw,3rem);border-top:1px solid var(--line)}.book-section.tint{margin-inline: