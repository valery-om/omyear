    .generated-book .message-section { padding-top: 6rem; }
    .generated-book .message__body { max-width: 42rem; }
    .generated-book .section-kicker { margin: 0 0 .65rem; color: var(--terracotta-deep); font-size: .62rem; letter-spacing: .2em; text-transform: uppercase; }
    .generated-book .nature__rows { display: flex; }
    .generated-book .places-list__item > span:last-child { min-width: 0; }
    .generated-book .letter-prompts { display: grid; grid-template-columns: repeat(3,minmax(0,1fr)); gap: 1rem; }
    .generated-book .prompt-card { display: grid; grid-template-columns: 2.2rem 1fr; gap: .8rem; padding: 1.1rem; border: 1px solid var(--line); border-radius: 1rem; background: rgba(251,244,230,.55); }
    .generated-book .prompt-card > span { color: var(--terracotta); font-family: var(--font-display); }
    .generated-book .prompt-card p { margin: 0; color: var(--ink-soft); line-height: 1.6; }
    .generated-book .provenance-section { margin-block: 3rem; padding: clamp(3rem,7vw,5rem) clamp(1.2rem,5vw,4rem); border: 1px solid var(--line); border-radius: 1.4rem; background: linear-gradient(145deg,rgba(251,244,230,.9),rgba(244,232,212,.55)); box-shadow: 0 28px 64px -48px rgba(70,48,28,.7); }
    .generated-book .provenance-section::before,.generated-book .provenance-section::after { display: none; }
    .generated-book .source-metrics { display: grid; grid-template-columns: repeat(4,minmax(0,1fr)); margin-bottom: 2rem; border: 1px solid var(--line); border-radius: 1rem; overflow: hidden; }
    .generated-book .source-metrics div { min-width: 0; padding: 1.25rem; border: 0; border-right: 1px solid var(--line); background: rgba(255,255,255,.22); }
    .generated-book .source-metrics div:last-child { border-right: 0; }
    .generated-book .source-metrics strong { display: block; color: var(--terracotta); font: 500 clamp(2.1rem,5vw,3.2rem)/1 var(--font-display); }
    .generated-book .source-metrics span { display: block; margin-top: .45rem; color: var(--sienna); font-size: .58rem; letter-spacing: .09em; line-height: 1.35; text-transform: uppercase; }
    .generated-book .ledger { border: 1px solid var(--line); border-radius: 1rem; overflow: hidden; background: rgba(251,244,230,.55); }
    .generated-book .ledger > summary { padding: 1rem 1.2rem; cursor: pointer; color: var(--terracotta-deep); font: 500 1rem/1.2 var(--font-display); }
    .generated-book .ledger-list { max-height: 32rem; overflow: auto; }
    .generated-book .ledger-list article { display: grid; grid-template-columns: minmax(11rem,.7fr) 1.3fr; gap: 1rem; padding: 1rem 1.2rem; border-top: 1px solid var(--line); }
    .generated-book .ledger-list code { color: var(--terracotta-deep); font-size: .68rem; overflow-wrap: anywhere; }
    .generated-book .ledger-list h3 { margin: 0; font: 500 .95rem/1.2 var(--font-display); }
    .generated-book .ledger-list p { margin: .35rem 0 0; color: var(--ink-soft); font-size: .75rem; line-height: 1.45; }
    .generated-book .method { margin: 1rem 0 0; color: var(--sienna)!important; font-size: .62rem!important; letter-spacing: .09em; line-height: 1.5; text-transform: uppercase; }
    .result-nav { position: fixed; z-index: 100; top: max(.75rem,env(safe-area-inset-top)); right: .8rem; left: auto; width: auto; max-width: calc(100vw - 1.6rem); margin: 0; padding: .38rem .45rem; border: 1px solid rgba(124,78,53,.2); border-radius: 999px; background: rgba(251,244,230,.88); box-shadow: 0 12px 30px -20px rgba(70,48,28,.8); backdrop-filter: blur(18px); opacity:0; pointer-events:none; transform:translateY(-.65rem); transition:opacity .3s ease,transform .3s ease; }
    .result-nav[data-visible="true"] { opacity:1; pointer-events:auto; transform:none; }
    .result-nav > .result-brand { padding: 0 .55rem; font-size: .82rem!important; }
    .result-brand span { width: .45rem; height: .45rem; }
    .result-nav button,.contents summary { padding: .48rem .68rem; }
    .result-nav .language-switch { background: transparent; }
    .empty { padding-inline: 1.2rem; }
    @media (max-width:780px) {
      .generated-book .letter-prompts { grid-template-columns: 1fr; }
