---
import Layout from "../layouts/Layout.astro";
import mayaDemo from "../data/people/maya-demo.json";

const demoData = JSON.stringify(mayaDemo).replaceAll("<", "\\u003c");
---

<Layout
  title="Your Omyear — private browser result"
  description="A private, source-linked personal year book generated from your permitted material."
  music={false}
  language="en"
>
  <main class="result-shell">
    <nav id="result-nav" class="result-nav" aria-label="Book controls">
      <a id="home-link" class="result-brand" href="/"><span aria-hidden="true"></span>omyear</a>
      <div class="result-tools">
        <div class="language-switch" aria-label="Language">
          <a id="language-ru" href="/try/?lang=ru" hreflang="ru">RU</a>
          <a id="language-en" href="/try/?lang=en" hreflang="en">EN</a>
        </div>
        <details id="contents" class="contents">
          <summary id="contents-label">Contents</summary>
          <div id="contents-list" class="contents-list"></div>
        </details>
        <button id="print" type="button">Print / PDF</button>
        <button id="clear" class="clear-book" type="button">Clear this book</button>
      </div>
    </nav>
    <div id="empty" class="empty" hidden><p>There is no generated book in this tab.</p><h1>Start with your<br /><em>own material.</em></h1><a href="/try">Create an Omyear →</a></div>
    <article id="book" class="book" hidden></article>
  </main>

  <script id="demo-book" type="application/json" set:html={demoData}></script>

  <script>
    const COPY = {
      en:{print:"Print / PDF",clear:"Clear",contents:"Contents",cover:"Cover",empty:"There is no generated book in this tab.",emptyTitle:"Start with your own material.",start:"Create an Omyear →",private:"private browser result",numbers:"the number layer",matrix:"the 22-arcana matrix",nature:"the design layer",year:"the year’s question",months:"twelve chapters",synergy:"the combined lens",places:"symbolic geography",traps:"watch with care",days:"the first twelve days",manifest:"a compact compass",letter:"leave a trace",sources:"source ledger",sourcesIntro:"The book can show the deterministic records its editorial claims were allowed to use.",sourceRecords:"source records",cited:"sources cited",errors:"source-link errors",review:"human review flags",method:"Method",status:"Verification",deleteConfirm:"Remove this generated book from this browser tab?",switchToRu:"Create a new Russian edition",switchToEn:"Create a new English edition"},
      ru:{print:"Печать / PDF",clear:"Удалить",contents:"Оглавление",cover:"Обложка",empty:"В этой вкладке нет созданной книги.",emptyTitle:"Начни со своего материала.",start:"Создать Omyear →",private:"приватный результат в браузере",numbers:"слой чисел",matrix:"матрица 22 арканов",nature:"слой дизайна",year:"вопрос года",months:"двенадцать глав",synergy:"общая оптика",places:"символическая география",traps:"на что смотреть бережно",days:"первые двенадцать дней",manifest:"короткий компас",letter:"оставить след",sources:"реестр источников",sourcesIntro:"Книга показывает детерминированные записи, которые редакторскому этапу было разрешено использовать.",sourceRecords:"источников",cited:"источников процитировано",errors:"ошибок связей",review:"флагов для редактора",method:"Метод",status:"Проверка",deleteConfirm:"Удалить созданную книгу из этой вкладки браузера?",switchToRu:"Создать новую книгу на русском",switchToEn:"Создать новую книгу на английском"}
    };
    const stored = sessionStorage.getItem("omyear:book");
    const demo = new URLSearchParams(location.search).get("demo") === "maya" ? JSON.parse(document.getElementById("demo-book").textContent) : null;
    const bookRoot = document.getElementById("book"); const empty = document.getElementById("empty");
    const make = (tag,className,text) => { const node=document.createElement(tag); if(className) node.className=className; if(text!==undefined&&text!==null) node.textContent=String(text); return node; };
    const appendTextItems = (parent,items,className="prose") => { const wrap=make("div",className); (items||[]).filter(Boolean).forEach((text)=>wrap.append(make("p","",typeof text==="string"?text:text.text))); parent.append(wrap); return wrap; };
    function section(kicker,title,intro,className="") { const node=make("section",`book-section ${className}`); const head=make("header","section-head"); head.append(make("p","section-kicker",kicker),make("h2","",title)); if(intro) head.append(make("p","section-intro",intro)); node.append(head); return node; }
    function cards(parent,items,render,className="cards") { const grid=make("div",className); (items||[]).forEach((item,index)=>grid.append(render(item,index))); parent.append(grid); return grid; }
    function localizeControls(lang) {
      const c=COPY[lang];
      const ru=document.getElementById("language-ru"); const en=document.getElementById("language-en");
      document.getElementById("print").textContent=c.print; document.getElementById("clear").textContent=c.clear; document.getElementById("contents-label").textContent=c.contents;
      document.getElementById("home-link").href=`/?lang=${lang}`;
      ru.title=c.switchToRu; en.title=c.switchToEn;
      [ru,en].forEach((link)=>link.removeAttribute("aria-current"));
      document.getElementById(`language-${lang}`).setAttribute("aria-current","page");
    }
    function buildContents(book,lang) {
      const c=COPY[lang]; const list=document.getElementById("contents-list"); list.replaceChildren();
      const cover=make("a","",c.cover); cover.href="#book-cover"; list.append(cover);
      bookRoot.querySelectorAll(":scope > .book-section").forEach((item,index)=>{item.id=`chapter-${index+1}`;const link=make("a","",item.querySelector("h2")?.textContent||String(index+1));link.href=`#${item.id}`;list.append(link)});
      list.querySelectorAll("a").forEach((link)=>link.addEventListener("click",()=>document.getElementById("contents").removeAttribute("open")));
    }
    function renderBook(book) {
      const lang=book.person.language==="ru"?"ru":"en"; const c=COPY[lang]; document.documentElement.lang=lang;
      document.title=lang==="ru"?`${book.person.name} — личный Omyear`:`${book.person.name} — personal Omyear`; localizeControls(lang);
      const hero=make("header","book-hero"); hero.id="book-cover"; hero.append(make("p","book-hero__kicker",book.hero.kicker),make("h1","",book.hero.title),make("p","book-hero__sub",book.hero.subtitle),make("p","book-hero__note",book.hero.note),make("span","book-hero__private",c.private)); bookRoot.append(hero);

      const message=section("01",book.message.heading); appendTextItems(message,book.message.paragraphs,"prose prose--lead"); bookRoot.append(message);
      const numbers=section(c.numbers,book.numbers.heading,book.numbers.intro,"tint"); cards(numbers,book.numbers.items,(item)=>{const card=make("article","number-card");card.append(make("strong","",item.value),make("h3","",item.name),make("p","",item.text));return card;},"number-grid"); numbers.append(make("p","synthesis",book.numbers.synthesis)); bookRoot.append(numbers);
      const matrix=section(c.matrix,book.matrix.heading,book.matrix.intro); cards(matrix,book.matrix.items,(item)=>{const card=make("article","matrix-card");card.append(make("span","",item.arcana),make("div",""));card.lastChild.append(make("p","matrix-role",item.role),make("h3","",item.name),make("p","",item.text));return card;}); matrix.append(make("p","synthesis",book.matrix.synthesis)); bookRoot.append(matrix);
      const nature=section(c.nature,book.nature.heading,book.nature.intro,"dark"); cards(nature,book.nature.design,(item)=>{const card=make("article","design-card");card.append(make("p","section-kicker",item.label),make("p","",item.text));return card;}); nature.append(make("h3","subheading",book.nature.strengthsHeading)); cards(nature,book.nature.strengths,(item)=>{const card=make("article","plain-card");card.append(make("h3","",item.title),make("p","",item.text));return card;}); bookRoot.append(nature);
      const year=section(c.year,book.yearTheme.heading,book.yearTheme.intro); appendTextItems(year,book.yearTheme.paragraphs); bookRoot.append(year);
      const months=section(c.months,book.months.heading,book.months.intro,"months-section"); const monthList=make("div","month-list"); book.months.items.forEach((item,index)=>{const detail=make("details","month");const summary=make("summary","");const left=make("div","");left.append(make("span","month-index",String(index+1).padStart(2,"0")),make("div",""));left.lastChild.append(make("h3","",item.month),make("p","",item.period));summary.append(left,make("strong","",item.topic));const content=make("div","month-content");content.append(make("p","month-house",item.house),make("h4","",item.note),make("p","",item.text),make("p","practice",book.monthPractices[index]));detail.append(summary,content);monthList.append(detail)});months.append(monthList);bookRoot.append(months);
      const synergy=section(c.synergy,book.synergy.heading); appendTextItems(synergy,book.synergy.paragraphs,"prose prose--lead"); bookRoot.append(synergy);
      const places=section(book.places.eyebrow||c.places,book.places.heading,book.places.intro,"dark"); cards(places,book.places.compass,(item,index)=>{const card=make("article","place-signal");card.append(make("span","",String(index+1).padStart(2,"0")),make("h3","",item.label),make("p","",item.text));return card;}); places.append(make("p","place-moment",book.places.moment)); appendTextItems(places,book.places.paragraphs); places.append(make("h3","subheading",book.places.citiesHeading)); cards(places,book.places.cities,(item)=>{const card=make("article","city-card");card.style.setProperty("--card-color",item.color);card.append(make("h3","",item.name),make("p","city-line",item.line),make("p","",item.text));return card;}); places.append(make("p","method",book.places.method),make("p","method",book.places.note)); bookRoot.append(places);
      const traps=section(c.traps,book.traps.heading,book.traps.intro); cards(traps,book.traps.items,(item)=>{const card=make("article","plain-card");card.append(make("h3","",item.title),make("p","",item.text),make("p","antidote",item.antidote));return card;}); traps.append(make("p","synthesis",book.traps.closing)); bookRoot.append(traps);
      const days=section(c.days,book.twelveDays.heading,book.twelveDays.intro,"tint"); cards(days,book.twelveDays.items,(item)=>{const card=make("article","day-card");card.append(make("span","",item.day),make("p","day-date",item.date),make("h3","",item.title),make("p","",item.text));return card;},"days-grid");bookRoot.append(days);
      const manifest=section(c.manifest,book.manifest.heading);appendTextItems(manifest,book.manifest.paragraphs,"manifest-copy");bookRoot.append(manifest);
      const letter=section(c.letter,book.letter.heading,book.letter.intro);cards(letter,book.letter.prompts,(item,index)=>{const card=make("article","prompt-card");card.append(make("span","",String(index+1).padStart(2,"0")),make("p","",item));return card;});letter.append(make("p","synthesis",book.letter.closing));bookRoot.append(letter);
      const verification=book.provenance.verification; const provenance=section(c.sources,c.sources,c.sourcesIntro,"provenance"); const metrics=make("div","source-metrics"); [[book.provenance.sourceCount,c.sourceRecords],[verification.referencedClaimCount,c.cited],[verification.invalidSourceIds.length+verification.missingSourcePaths.length+verification.structuralErrors.length,c.errors],[verification.humanReview.flaggedPaths.length,c.review]].forEach(([value,label])=>{const metric=make("div","");metric.append(make("strong","",value),make("span","",label));metrics.append(metric)});provenance.append(metrics);const details=make("details","ledger");details.append(make("summary","",`${c.sources} · ${book.provenance.sourceCount}`));const list=make("div","ledger-list");book.provenance.sourceRecords.forEach((source)=>{const row=make("article","");const id=make("code","",source.id);const body=make("div","");body.append(make("h3","",source.label),make("p","",`${c.method}: ${source.method}`));row.append(id,body);list.append(row)});details.append(list);provenance.append(details,make("p","method",`${c.status}: ${verification.status} · ${book.provenance.generationModel}`));bookRoot.append(provenance);
      const footer=make("footer","book-footer");footer.append(make("p","",book.footer.disclaimer),make("p","",book.footer.signoff));bookRoot.append(footer);
      buildContents(book,lang);
    }
    if (!stored && !demo) { empty.hidden=false; const lang=new URLSearchParams(location.search).get("lang")==="ru"?"ru":"en";const c=COPY[lang];document.documentElement.lang=lang;localizeControls(lang);empty.querySelector("p").textContent=c.empty;empty.querySelector("h1").textContent=c.emptyTitle;empty.querySelector("a").textContent=c.start;empty.querySelector("a").href=`/try/?lang=${lang}`;document.getElementById("print").hidden=true;document.getElementById("clear").hidden=true;document.getElementById("contents").hidden=true; }
    else { try { renderBook(stored ? JSON.parse(stored) : demo); bookRoot.hidden=false; } catch { sessionStorage.removeItem("omyear:book"); empty.hidden=false; } }
    document.getElementById("print").addEventListener("click",()=>print());
    document.getElementById("clear").addEventListener("click",()=>{const lang=document.documentElement.lang==="ru"?"ru":"en";if(confirm(COPY[lang].deleteConfirm)){sessionStorage.removeItem("omyear:book");location.href=`/try?lang=${lang}`;}});
    document.addEventListener("click",(event)=>{const contents=document.getElementById("contents");if(contents.open&&!contents.contains(event.target))contents.removeAttribute("open")});
  </script>

  <style is:global>
    .empty[hidden],.book[hidden]{display:none!important}
    .result-shell{max-width:76rem;margin:0 auto;padding:0 1.3rem}.result-nav{position:relative;z-index:5;display:flex;justify-content:space-between;gap:1rem;padding:1.2rem 0;border-bottom:1px solid var(--line)}.result-nav>a{color:var(--ink);font:600 1.05rem/1 var(--font-display);text-decoration:none}.result-nav div{display:flex;gap:.5rem}.result-nav button{border:1px solid var(--line);border-radius:999px;background:transparent;padding:.5rem .75rem;color:var(--sienna);font-size:.62rem;cursor:pointer}.empty{min-height:80svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center}.empty p{color:var(--sienna);font-size:.7rem;letter-spacing:.15em;text-transform:uppercase}.empty h1{margin:.5rem 0 1.8rem;font:500 clamp(3rem,8vw,6rem)/.95 var(--font-display)}.empty h1 em{color:var(--terracotta)}.empty a{color:var(--paper);background:var(--terracotta);border-radius:999px;padding:.8rem 1rem;text-decoration:none}.book-hero{position:relative;min-height:88svh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;overflow:hidden}.book-hero:before{content:"";position:absolute;width:min(38rem,80vw);aspect-ratio:1;border-radius:50%;background:radial-gradient(circle,var(--sun),transparent 68%);opacity:.6;z-index:-1}.book-hero__kicker,.section-kicker{color:var(--terracotta-deep);font-size:.62rem;letter-spacing:.2em;text-transform:uppercase}.book-hero h1{margin:.3rem 0;font:500 clamp(4rem,12vw,9rem)/.85 var(--font-display);letter-spacing:-.05em}.book-hero__sub{font:italic 400 clamp(1.2rem,3vw,2rem)/1.2 var(--font-display);color:var(--sienna)}.book-hero__note{max-width:35rem;color:var(--ink-soft)}.book-hero__private{position:absolute;bottom:2rem;padding:.45rem .7rem;border:1px solid var(--line);border-radius:999px;color:var(--sienna);font-size:.57rem;letter-spacing:.12em;text-transform:uppercase}.book-section{padding:6rem clamp(0rem,4vw,3rem);border-top:1px solid var(--line)}.book-section.tint{margin-inline:-1.3rem;padding-inline:clamp(1.3rem,6vw,5rem);background:rgba(251,244,230,.72)}.book-section.dark{margin-inline:-1.3rem;padding-inline:clamp(1.3rem,6vw,5rem);background:#4b2935;color:#f7ebd5;border-color:#735060}.section-head{max-width:48rem;margin:0 auto 3.5rem;text-align:center}.section-head h2{margin:.3rem 0 0;font:500 clamp(2.5rem,6vw,5rem)/.95 var(--font-display);letter-spacing:-.035em}.section-intro{max-width:38rem;margin:1.3rem auto 0;color:var(--ink-soft);line-height:1.7}.dark .section-intro,.dark .prose{color:#d4bfb4}.prose{max-width:46rem;margin:0 auto;color:var(--ink-soft);font-size:1.03rem;line-height:1.85}.prose--lead{font:400 clamp(1.3rem,2.5vw,1.8rem)/1.65 var(--font-display);color:var(--ink)}.number-grid,.cards{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}.number-card,.plain-card,.design-card{padding:1.3rem;border:1px solid var(--line);border-radius:16px}.number-card strong{color:var(--terracotta);font:500 3.5rem/1 var(--font-display)}.number-card h3,.plain-card h3,.design-card h3,.matrix-card h3,.city-card h3,.day-card h3{font:600 1.2rem/1.2 var(--font-display)}.number-card p,.plain-card p,.design-card p,.matrix-card p,.city-card p,.day-card p{color:var(--ink-soft);font-size:.85rem;line-height:1.65}.synthesis{max-width:42rem;margin:3rem auto 0;text-align:center;color:var(--sienna);font:italic 400 1.25rem/1.55 var(--font-display)}.matrix-card{display:grid;grid-template-columns:3rem 1fr;gap:1rem;padding:1.2rem 0;border-bottom:1px solid var(--line)}.matrix-card>span{color:var(--terracotta);font:500 2rem/1 var(--font-display)}.matrix-role,.city-line,.day-date,.method{color:var(--gold)!important;font-size:.62rem!important;letter-spacing:.08em;text-transform:uppercase}.subheading{margin:3.5rem 0 1.2rem;font:500 2rem/1 var(--font-display)}.dark .cards article{border-color:#805e60}.dark .cards p{color:#d4bfb4}.month-list{border-top:1px solid var(--line)}.month{border-bottom:1px solid var(--line)}.month summary{display:grid;grid-template-columns:1fr 1fr;gap:1rem;align-items:center;padding:1.4rem 0;cursor:pointer;list-style:none}.month summary>div{display:flex;align-items:center;gap:1rem}.month-index{color:var(--gold);font-size:.65rem}.month h3{margin:0;font:500 1.7rem/1 var(--font-display)}.month summary p{margin:.3rem 0 0;color:var(--sienna);font-size:.7rem}.month summary strong{text-align:right;color:var(--terracotta-deep);font:500 1.1rem/1.2 var(--font-display)}.month-content{max-width:42rem;margin:0 auto;padding:1rem 0 2.4rem}.month-content h4{font:500 1.35rem/1.2 var(--font-display)}.month-content>p{color:var(--ink-soft);line-height:1.7}.practice{padding:1rem;border-left:2px solid var(--terracotta);background:rgba(251,244,230,.65)}.place-signal span{color:var(--gold)}.place-moment{max-width:48rem;margin:3rem auto;padding:.8rem;border:1px solid #805e60;border-radius:999px;text-align:center;color:#d4bfb4;font-size:.72rem}.city-card{padding:1.2rem;border-top:3px solid var(--card-color);background:rgba(255,255,255,.04)}.days-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.day-card{padding:1.2rem;border:1px solid var(--line);border-radius:14px}.day-card>span{color:var(--terracotta);font:500 2rem/1 var(--font-display)}.manifest-copy{max-width:52rem;margin:0 auto}.manifest-copy p{margin:.5rem 0;text-align:center;font:500 clamp(1.6rem,4vw,3.2rem)/1.15 var(--font-display)}.prompt-card{display:grid;grid-template-columns:2.5rem 1fr;gap:.8rem;padding:1rem 0;border-bottom:1px solid var(--line)}.prompt-card span{color:var(--gold)}.source-metrics{display:grid;grid-template-columns:repeat(4,1fr);margin-bottom:2rem}.source-metrics div{padding:1rem;border:1px solid var(--line);border-right:0}.source-metrics div:last-child{border-right:1px solid var(--line)}.source-metrics strong{display:block;color:var(--terracotta);font:500 2.5rem/1 var(--font-display)}.source-metrics span{font-size:.58rem;letter-spacing:.08em;text-transform:uppercase}.ledger{border:1px solid var(--line);border-radius:16px;overflow:hidden}.ledger>summary{padding:1rem;cursor:pointer}.ledger-list article{display:grid;grid-template-columns:minmax(12rem,.7fr) 1fr;gap:1rem;padding:1rem;border-top:1px solid var(--line)}.ledger-list code{font-size:.7rem;color:var(--terracotta-deep);overflow-wrap:anywhere}.ledger-list h3{margin:0;font:600 1rem/1.2 var(--font-display)}.ledger-list p{margin:.4rem 0 0}.book-footer{margin-inline:-1.3rem;padding:3rem clamp(1.3rem,6vw,5rem);background:#3f2730;color:#d4bfb4}.book-footer p{max-width:50rem;margin:.7rem auto;text-align:center;font-size:.75rem;line-height:1.6}
    .result-nav{position:sticky;top:.75rem;z-index:50;align-items:center;margin-top:.75rem;padding:.55rem .65rem .55rem .8rem;border:1px solid rgba(124,78,53,.2);border-radius:999px;background:rgba(255,250,239,.88);box-shadow:0 14px 40px rgba(75,41,53,.12);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px)}.result-nav>a.result-brand{display:flex;align-items:center;gap:.5rem;color:var(--ink);font:600 1.05rem/1 var(--font-display);text-decoration:none}.result-brand span{width:.6rem;height:.6rem;border-radius:50%;background:var(--terracotta);box-shadow:0 0 0 .25rem rgba(221,125,76,.12)}.result-nav .result-tools{display:flex;align-items:center;gap:.45rem}.result-nav button,.contents summary{border:1px solid var(--line);border-radius:999px;background:transparent;padding:.54rem .78rem;color:var(--sienna);font-size:.62rem;line-height:1;cursor:pointer;white-space:nowrap}.result-nav button:hover,.contents summary:hover{border-color:var(--terracotta);color:var(--terracotta-deep)}.result-nav .language-switch{display:flex;align-items:center;gap:0;padding:.18rem;border:1px solid var(--line);border-radius:999px;background:rgba(255,255,255,.48)}.language-switch a{min-width:2rem;padding:.36rem .48rem;border-radius:999px;color:var(--sienna);font:600 .58rem/1 var(--font-sans);letter-spacing:.08em;text-align:center;text-decoration:none}.language-switch a[aria-current="page"]{background:var(--terracotta);color:#fff;pointer-events:none}.contents{position:relative}.contents summary{list-style:none}.contents summary::-webkit-details-marker{display:none}.result-nav .contents-list{position:absolute;top:calc(100% + .7rem);right:0;display:grid;width:min(22rem,80vw);max-height:min(70vh,38rem);overflow:auto;padding:.55rem;border:1px solid rgba(124,78,53,.2);border-radius:18px;background:rgba(255,250,239,.98);box-shadow:0 20px 60px rgba(75,41,53,.18)}.contents-list a{padding:.72rem .8rem;border-radius:12px;color:var(--ink-soft);font:500 .9rem/1.2 var(--font-display);text-decoration:none}.contents-list a:hover{background:var(--blush);color:var(--terracotta-deep)}.book-hero,.book-section{scroll-margin-top:6rem}
    @media(max-width:780px){.number-grid,.cards{grid-template-columns:1fr 1fr}.days-grid{grid-template-columns:1fr 1fr}.source-metrics{grid-template-columns:1fr 1fr}.source-metrics div{border:1px solid var(--line)}.ledger-list article{grid-template-columns:1fr}.clear-book{font-size:0!important}.clear-book:after{content:"×";font-size:.85rem}.result-nav{top:.45rem}.result-nav .result-tools{flex-direction:row;gap:.3rem}.result-nav .language-switch{flex-direction:row}}@media(max-width:560px){.result-shell{padding-inline:.65rem}.result-nav{padding-left:.65rem}.result-brand{font-size:.95rem!important}.result-brand span{display:none}.contents summary{font-size:0}.contents summary:after{content:"☰";font-size:.75rem}.result-nav button,.contents summary{padding:.52rem .62rem}.language-switch a{min-width:1.75rem;padding-inline:.35rem}.book-section.tint,.book-section.dark,.book-footer{margin-inline:-.65rem}.number-grid,.cards,.days-grid{grid-template-columns:1fr}.month summary{grid-template-columns:1fr}.month summary strong{text-align:left}.book-section{padding-block:4rem}.place-moment{border-radius:16px}}@media print{.result-nav{display:none}.book-section{break-inside:avoid}.book{display:block!important}.book-hero{min-height:90vh}}
  </style>
</Layout>
