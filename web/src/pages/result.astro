      .result-nav .language-switch { display: none; }
      .generated-book .source-metrics { grid-template-columns: 1fr; }
      .generated-book .source-metrics div { border-right: 0; border-bottom: 1px solid var(--line); }
      .generated-book .source-metrics div:last-child { border-bottom: 0; }
    }
    @media print { .result-nav { display: none!important; } }
