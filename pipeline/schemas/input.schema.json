{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Omyear pipeline input",
  "type": "object",
  "additionalProperties": false,
  "required": ["project", "person", "candidateLocations"],
  "properties": {
    "$schema": { "type": "string" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "targetYear", "style", "experience"],
      "properties": {
        "language": { "type": "string", "enum": ["en", "ru"] },
        "targetYear": { "type": "integer", "minimum": 2020, "maximum": 2100 },
        "style": { "type": "string" },
        "experience": { "type": "string" },
        "publicDemo": { "type": "boolean", "default": false }
      }
    },
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "fullNameAtBirth", "birth", "solarReturnLocation", "goals", "facts", "giftMessage"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string", "minLength": 1 },
        "fullNameAtBirth": { "type": "string", "minLength": 1 },
        "birth": { "$ref": "#/$defs/locationWithBirth" },
        "solarReturnLocation": { "$ref": "#/$defs/location" },
        "goals": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fact" }
        },
        "facts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/fact" }
        },
        "giftMessage": { "type": "string", "minLength": 1 }
      }
    },
    "candidateLocations": {
      "type": "array",
      "items": { "$ref": "#/$defs/candidateLocation" }
    }
  },
  "$defs": {
    "fact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "text": { "type": "string", "minLength": 1 }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["place", "latitude", "longitude", "utcOffset"],
      "properties": {
        "place": { "type": "string" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "utcOffset": { "type": "string", "pattern": "^[+-][0-2][0-9]:[0-5][0-9]$" }
      }
    },
    "locationWithBirth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["place", "latitude", "longitude", "utcOffset", "date", "time"],
      "properties": {
        "place": { "type": "string" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
        "utcOffset": { "type": "string", "pattern": "^[+-][0-2][0-9]:[0-5][0-9]$" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string", "pattern": "^[0-2][0-9]:[0-5][0-9]$" }
      }
    },
    "candidateLocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "country", "latitude", "longitude"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "country": { "type": "string" },
        "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    }
  }
}
