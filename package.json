{
  "name": "omyear-build-week",
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm --prefix web run dev",
    "test": "node --test pipeline/tests/pipeline.test.mjs",
    "build": "npm --prefix web run build",
    "deploy:pages": "wrangler pages deploy web/dist --project-name omyear --branch main",
    "audit": "node scripts/audit-public.mjs",
    "audit:deps": "npm audit --audit-level=moderate && npm --prefix web audit --audit-level=moderate",
    "check:worker": "npm --prefix worker run check",
    "check": "npm run test && npm run build && npm run check:worker && npm run audit && npm run audit:deps"
  },
  "devDependencies": {
    "wrangler": "^4.112.0"
  }
}
